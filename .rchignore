# Project-specific RCH sync exclusions.
#
# RCH reads this file for normal project upload and artifact retrieval. Keep
# patterns narrow: this file must not hide source, fixtures, migrations, or
# other inputs required for remote Cargo verification.
#
# RCH's custom CARGO_TARGET_DIR pullback is rooted at the target directory, not
# this repo root, so these rules do not suppress that separate artifact sync.
# For verification-only runs, prefer:
#
#   env -u CARGO_TARGET_DIR rch exec -- cargo check --all-targets
#
# If artifacts must be pulled back, point CARGO_TARGET_DIR at disk-backed
# storage such as ${TMPDIR:-/data/tmp}/rch_target_<task>, not /tmp.

# Cargo/RCH build outputs. Remote verification does not need local build
# artifacts copied back into this checkout.
/target/
/target/**
/.rch-target/
/.rch-target/**

# Machine-local Cargo config may point at host-only scratch disks such as
# /Volumes/USBNVME16TB. RCH sets worker-local target dirs explicitly.
.cargo/config.toml

# `src/cache` is a real Rust module. Keep it visible even when host-level
# ignore files contain broad cache-directory exclusions.
!src/cache/
!src/cache/**

# Diagnostic output files created by verification scripts
.clippy_out.txt
.closure-lint-report.json
.ubs_out.txt
.vision-coverage-report.json
.git_log_tmp.txt
clippy_out_dump
exit_code_test_out
recent_commits.txt

# Machine-local ee workspace runtime state. Remote Cargo verification should
# build and test source, not copy this checkout's local database/index/cache
# stores into worker project roots.
.ee/
.ee/**

# Root-level scratch artifacts observed from agent diagnostics and ad hoc
# verifier probes. Keep these exact so source, fixtures, migrations, docs, and
# tests remain visible to RCH.
/--help
/.plan-drift-report.json
/critical.json
/functions.txt
/test_ln_1p
/test_ln_1p.rs
/test_multibyte
/test_multibyte.rs
/ubs.json
/ubs_findings.jsonl
/ubs_full.txt

# Volatile Beads SQLite sidecars and temp files. Keep .beads/issues.jsonl
# visible for tests and coordination, but do not let transient DB files make
# RCH fall back to local execution when they vanish during rsync.
.beads/*.db
.beads/*db-shm
.beads/*db-wal
.beads/*db-journal
.beads/.*.db.*
.beads/bd.sock*
.beads/daemon.lock
.beads/daemon.log
.beads/last-touched

# Agent session reports (multi-pane orchestration artifacts)
GEMINI_PANE*.md
GEMINI_PANE_REPORT.md

# Per-agent target directories (these are in /tmp but pattern for completeness)
/tmp/ee_target_pane*/

# Broken shell expansion artifacts
${TMPDIR:-/
.../
.../**

# perf profiling data (already in global config but explicit here)
perf.data
perf.data.*

# Test run artifacts
*.test_output
*.test_log

# Volatile audit pointers can be transient/broken symlinks and are not inputs to
# remote Cargo verification.
tests/audit_artifacts/latest_*.json

# bd-1h8ji.4 — AppleDouble / macOS Finder metadata. These files are created on
# Mac when extended attributes are stored on filesystems that don't natively
# support them (USB drives, ExFAT, network shares). They are NOT source inputs
# to remote Cargo verification, and vendored C crates such as `zstd-sys` will
# attempt to compile any `._foo.c` sibling next to `foo.c` if they end up in
# the worker file set, poisoning the build. Excluding here keeps remote Linux
# verification consistent regardless of which Mac filesystem the Mac-side
# checkout lives on.
._*
**/._*
.DS_Store
**/.DS_Store
