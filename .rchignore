# Project-specific RCH sync exclusions.
#
# RCH reads this file for normal project upload and artifact retrieval. Keep
# patterns narrow: this file must not hide source, fixtures, migrations, or
# other inputs required for remote Cargo verification.
#
# RCH's custom CARGO_TARGET_DIR pullback is rooted at the target directory, not
# this repo root, so these rules do not suppress that separate artifact sync.
# For verification-only runs, prefer:
#
#   env -u CARGO_TARGET_DIR rch exec -- cargo check --all-targets
#
# If artifacts must be pulled back, point CARGO_TARGET_DIR at disk-backed
# storage such as ${TMPDIR:-/data/tmp}/rch_target_<task>, not /tmp.

# Cargo/RCH build outputs. Remote verification does not need local build
# artifacts copied back into this checkout.
/target/
/target/**
/.rch-target/
/.rch-target/**

# Machine-local Cargo config may point at host-only scratch disks such as
# /Volumes/USBNVME16TB. RCH sets worker-local target dirs explicitly.
.cargo/config.toml

# Diagnostic output files created by verification scripts
.clippy_out.txt
.closure-lint-report.json
.ubs_out.txt
.vision-coverage-report.json
.git_log_tmp.txt
clippy_out_dump
exit_code_test_out
recent_commits.txt

# Agent session reports (multi-pane orchestration artifacts)
GEMINI_PANE*.md
GEMINI_PANE_REPORT.md

# Per-agent target directories (these are in /tmp but pattern for completeness)
/tmp/ee_target_pane*/

# Broken shell expansion artifacts
${TMPDIR:-/
.../
.../**

# perf profiling data (already in global config but explicit here)
perf.data
perf.data.*

# Test run artifacts
*.test_output
*.test_log
