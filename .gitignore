# Rust build artifacts
/target*
**/*.rs.bk

# Machine-local Cargo target override. This repo's local checkout points Cargo
# at external scratch storage so build artifacts do not fill the system disk.
.cargo/config.toml

# The project has a real Rust module at src/core. Some developer machines have
# broad global ignores for "core", so keep this module visible to Git.
!src/core/
!src/core/**
!src/cache/
!src/cache/**

# ee project-local state
.ee/

# Agent swarm / coordination state
.ntm/

# Beads (br) state — track JSONL + project config; per-machine state
# (database, locks, history, sync caches) is excluded by .beads/.gitignore.
# The blanket .beads/ exclusion that used to live here also hid issues.jsonl,
# which is the canonical task-tracking source of truth and MUST be committed.
#
# Project-side additions that the upstream br .beads/.gitignore template
# does not (yet) cover. These are dated per-machine artifacts created by
# `br doctor`, `br migrate`, and `br upgrade`; the JSONL/metadata/config
# files allow-listed under .beads/.gitignore remain tracked.
/.beads.recovery_*/
.beads/recovery_*/
.beads/.br_history/
.beads/last-touched
.beads/daemon.lock.stale_*
.beads/issues.jsonl.pre_*
.beads/issues.jsonl.truncated_*
# Tool-installed marketing README under .beads/ — not authored by this
# project. If a real .beads/README.md ever becomes intentional, add it
# with `git add -f`.
.beads/README.md

# Modes-of-reasoning analysis artifacts
MODES_OF_REASONING_REPORT_AND_ANALYSIS_OF_PROJECT.md
MODES_ANALYSIS_PROGRESS.md
MODE_OUTPUT_*.md

# Editor / OS junk
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
.directory
.Trashes
.Spotlight-V100
*.swp
*.swo
*~
.idea/
.vscode/
.fleet/
.zed/
.helix/

# Generic temp / backup / merge-conflict artifacts
*.bak
*.tmp
*.orig
*.rej
*.log
*.pid
*.lock.tmp
*.partial
.tmp/
.cache/
scratch/
scratch.*
**/*.bak

# Insta review proposals are generated artifacts; accepted goldens are *.snap.
*.snap.new

# Rust profiling / coverage / nextest local outputs
*.profraw
*.profdata
*.gcda
*.gcno
lcov.info
coverage/
tarpaulin-report.*
.tarpaulin/
nextest.toml.local
**/*.rs.orig
Cargo.lock.bak

# Local env / direnv (real .env should be checked in only if intentional)
.env.local
.env.*.local
.envrc.local

# Agent / tool runtime scratch (not authoritative state)
.agent-mail/
.cass/
.rch/
.claude/
.codex/
.codex_write_probe
.cursor/
.stash_janitor_workspace/
# mcp-agent-mail per-project Python stub installed by `install_guard`.
# The real coordinator lives outside this repo; the on-disk stub is
# scratch and must never be committed.
/mcp_agent_mail/
!tests/fixtures/agent_detect/remote_mirror/
!tests/fixtures/agent_detect/remote_mirror/**
!tests/fixtures/agent_detect/remote_mirror/**/.claude/
!tests/fixtures/agent_detect/remote_mirror/**/.claude/**
!tests/fixtures/agent_detect/remote_mirror/**/.codex/
!tests/fixtures/agent_detect/remote_mirror/**/.codex/**

# Python tooling caches (some helper scripts may run python)
__pycache__/
*.pyc
*.pyo
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Node tooling caches (only if used by helper scripts)
node_modules/

# bv (beads viewer) local config and caches
.bv/
.env
.claude/settings.local.json

# Per-run e2e overhaul suite logs (J3/J4). Each run writes a timestamped
# directory under tests/logs/; keep them off git.
tests/logs/

# One-off ad-hoc helper scripts agents occasionally drop in the repo root
# while investigating an issue. These are not authoritative tooling — they
# are scratch. Keep them off git so they don't sneak into commits.
/find_async_sleep.sh
/fix_unwrap_err.sh
/patch.py

# scripts/audit_install_pipeline.sh writes a timestamped JSON snapshot per
# run into tests/audit_artifacts/. The "latest_install_pipeline.json" symlink
# and an occasional `git add -f`'d baseline are the authoritative artifacts;
# every other timestamped run is scratch and should not pile up in git.
tests/audit_artifacts/install_pipeline_*.json
!tests/audit_artifacts/install_pipeline_2026-05-13T052258Z.json
!tests/audit_artifacts/install_pipeline_2026-05-13T192108Z.json
