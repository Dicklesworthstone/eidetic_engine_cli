set shell := ["sh", "-cu"]

eql-parser-ci:
  cd .. && cargo +nightly fuzz run eql_parser -- -max_total_time=300 -timeout=10

eql-parser-check:
  cd .. && cargo +nightly fuzz check eql_parser

pack-token-budget-ci:
  cd .. && cargo +nightly fuzz run pack_token_budget -- -max_total_time=300 -timeout=10

pack-token-budget-check:
  cd .. && cargo +nightly fuzz check pack_token_budget

packing-budget-ci:
  cd .. && cargo +nightly fuzz run packing_budget -- -max_total_time=600 -timeout=10

packing-budget-check:
  cd .. && cargo +nightly fuzz check packing_budget

search-query-parser-ci:
  cd .. && cargo +nightly fuzz run search_query_parser -- -max_total_time=900 -timeout=10

search-query-parser-check:
  cd .. && cargo +nightly fuzz check search_query_parser
