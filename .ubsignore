# UBS (Ultimate Bug Scanner) ignore globs for ee.
#
# UBS already auto-skips target/ and Cargo.lock; this file supplements
# those defaults with patterns specific to ee. Globs follow gitignore
# conventions (relative to repo root unless leading `/`).

# Auto-generated proptest seed files — opaque text reproducers, not
# human-authored code. Scanning them generates noise.
proptest-regressions/

# Fuzz corpora and artifacts — inputs are intentionally malformed and
# crash outputs reflect deliberate failures. Build output under target/.
fuzz/corpus/
fuzz/artifacts/
fuzz/target/

# tests/fixtures/ holds pinned reference content: failure-mode fixtures
# (deliberately degraded), goldens (frozen contracts), schema examples,
# swarm corpora, redaction probes. No .rs source lives here; UBS
# findings would be false positives against intentional shapes.
tests/fixtures/

# Insta accepted snapshots — generated by the cargo insta workflow,
# not authored prose or code.
tests/snapshots/

# Beads JSONL is a multi-megabyte issue-tracker data file, not code.
.beads/issues.jsonl
