schema: ee.response.v1
success: true
fields: standard
data:
  command: status
  version: 0.1.0
  workspace:
    source: explicit
    root: $STATUS_WORKSPACE
    configDir: $STATUS_WORKSPACE/.ee
    markerPresent: false
    canonicalRoot: $STATUS_WORKSPACE
    fingerprint: <workspace-fingerprint>
    scopeKind: standalone
    repositoryRoot: null
    repositoryFingerprint: null
    subprojectPath: null
    diagnostics[1]{code,severity,message,repair,selectedSource,selectedRoot,conflictingSource,conflictingRoot}:
      workspace_selected_differs_from_discovered,warning,The selected workspace differs from the nearest initialized workspace discovered from the current directory.,Confirm --workspace/EE_WORKSPACE before running mutating commands.,explicit,$STATUS_WORKSPACE,discovered,/data/projects/eidetic_engine_cli
  capabilities:
    runtime: ready
    storage: pending
    search: pending
    output:
      toon: ready
    agentDetection: ready
  runtime:
    engine: asupersync
    profile: current_thread
    workerThreads: 1
    asyncBoundary: core
  memoryHealth:
    status: unavailable
    totalCount: 0
    activeCount: 0
    tombstonedCount: 0
    staleCount: 0
    healthScore: null
    averageConfidence: null
    provenanceCoverage: null
    scoreComponents:
      activeRatio: null
      freshnessScore: null
      confidenceScore: null
      provenanceScore: null
      tombstonePenalty: null
  curationHealth:
    status: unavailable
    totalCount: 0
    pendingCount: 0
    acceptedCount: 0
    snoozedCount: 0
    rejectedCount: 0
    dueCount: 0
    promptCount: 0
    escalationCount: 0
    blockedCount: 0
    policyCount: 0
    autoPromoteEnabledCount: 0
    oldestPendingAgeDays: null
    meanReviewLatencyDays: null
    nextScheduledAt: null
  feedbackHealth:
    status: unavailable
    harmfulPerSourcePerHour: 5
    harmfulBurstWindowSeconds: 3600
    perSourceHarmfulCounts[0]:
    quarantineQueueDepth: 0
    protectedRuleCount: 0
    lastInversionEvent: null
    nextDeterministicAction: run ee init --workspace .
  derivedAssets[2]{name,status,sourceHighWatermark,assetHighWatermark,highWatermarkLag,path}:
    search_index,missing,null,null,null,.ee/index
    graph_snapshot,unimplemented,null,null,null,.ee/graph
  agentInventory:
    schema: ee.agent.status.v1
    status: not_inspected
    formatVersion: 1
    summary:
      detectedCount: 0
      totalCount: 22
    inspectionCommand: ee agent status --json
    degraded[0]:
  degraded[5]{code,severity,message}:
    storage_not_initialized,medium,Workspace storage is unavailable because .ee/ee.db is missing.
    search_waiting_for_storage,medium,Search readiness is pending until workspace storage is initialized.
    memory_health_unavailable,low,Memory health is unavailable because the workspace database is missing.
    curation_health_unavailable,low,Curation health is unavailable because the workspace database is missing.
    feedback_health_unavailable,low,Feedback health is unavailable because the workspace database is missing.
