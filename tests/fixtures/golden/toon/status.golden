schema: ee.response.v1
success: true
fields: standard
data:
  command: status
  version: 0.1.0
  capabilities:
    runtime: ready
    storage: unimplemented
    search: unimplemented
    agentDetection: ready
  runtime:
    engine: asupersync
    profile: current_thread
    workerThreads: 1
    asyncBoundary: core
  memoryHealth:
    status: unavailable
    totalCount: 0
    activeCount: 0
    tombstonedCount: 0
    staleCount: 0
    healthScore: null
    averageConfidence: null
    provenanceCoverage: null
    scoreComponents:
      activeRatio: null
      freshnessScore: null
      confidenceScore: null
      provenanceScore: null
      tombstonePenalty: null
  derivedAssets[2]{name,status,sourceHighWatermark,assetHighWatermark,highWatermarkLag,path}:
    search_index,not_inspected,null,null,null,.ee/index
    graph_snapshot,unimplemented,null,null,null,.ee/graph
  agentInventory:
    schema: ee.agent.status.v1
    status: not_inspected
    formatVersion: 1
    summary:
      detectedCount: 0
      totalCount: 22
    inspectionCommand: ee agent status --json
    degraded[0]:
