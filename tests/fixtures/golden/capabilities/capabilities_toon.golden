      canonicalSourceFormat: json
      dependency:
        crate: toon
        package: tru
        version: 0.2.3
        sourceKind: path
        path: /data/projects/toon_rust
        defaultFeatures: false
      supportedOutputProfiles[4]: minimal,summary,standard,full
      defaultFormatEnv: TOON_DEFAULT_FORMAT
      errorCodes[2]: toon_decode_failed,toon_encoding_failed
    sizeDiagnostics[2]:
      - command: status
        diagnostic:
          schema: ee.output_size_diagnostic.v1
          json:
            bytes: 2427
            estimatedTokens: 624
          toon:
            bytes: 2443
            estimatedTokens: 675
          savings:
            bytes: -16
            tokens: -51
            compressionRatio: 1.007
