schema: ee.response.v1
success: true
data:
  command: capabilities
  version: 0.1.0
  subsystems[5]{name,status,description}:
    runtime,ready,Asupersync async runtime
    storage,ready,FrankenSQLite/SQLModel persistence
    search,degraded,Frankensearch hybrid retrieval
    graph,ready,FrankenNetworkX graph analytics
    cass,pending,CASS session import adapter
  features[7]{name,enabled,description}:
    fts5,true,FTS5 full-text search
    json,true,JSON extension support
