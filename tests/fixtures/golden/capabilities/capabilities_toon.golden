    EE_HARMFUL_BURST_WINDOW_SECONDS,tuning,Override the harmful feedback burst window in seconds.,null,false,unset
    EE_HARMFUL_PER_SOURCE_PER_HOUR,tuning,Override the harmful feedback rate limit per source.,null,false,unset
    EE_HOOK_MODE,output,Use hook-oriented machine output defaults.,null,false,unset
    EE_INDEX_DIR,paths,Override the configured search index directory.,null,false,unset
    EE_JSON,output,Request JSON output from renderer auto-detection.,null,false,unset
    EE_LOG_FORMAT,diagnostics,Select structured log format.,null,false,unset
    EE_LOG_JSON,diagnostics,Enable JSON command-start logs on stderr.,null,false,unset
    EE_MAX_TOKENS,tuning,Override the default context pack token budget.,null,false,unset
    EE_NO_COLOR,output,Disable colored diagnostics.,null,false,unset
    EE_OUTPUT_FORMAT,output,Select the default output renderer.,null,false,unset
    EE_PREFLIGHT_BYPASS_SECRET,policy,Supply preflight bypass secret material.,null,false,unset
    EE_PROFILE,tuning,Override the default context pack profile.,null,false,unset
