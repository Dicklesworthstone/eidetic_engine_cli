{
  "schema": "ee.recorder.schemas.v1",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:recorder-run:v1",
      "eeSchema": "ee.recorder.run.v1",
      "kind": "recorder_run",
      "title": "RecorderRunMeta",
      "description": "Metadata for one append-only recorder run.",
      "type": "object",
      "required": [
        "schema",
        "runId",
        "agentId",
        "status",
        "startedAt",
        "eventCount",
        "redactedCount"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "runId", "type": "string", "required": true, "description": "Stable recorder run identifier."},
        {"name": "agentId", "type": "string", "required": true, "description": "Agent identity that owns the run."},
        {"name": "sessionId", "type": "string|null", "required": false, "description": "Optional upstream harness or CASS session identifier."},
        {"name": "workspaceId", "type": "string|null", "required": false, "description": "Optional ee workspace identifier."},
        {"name": "status", "type": "string", "required": true, "description": "Recorder run lifecycle status."},
        {"name": "startedAt", "type": "string", "required": true, "description": "RFC 3339 start timestamp."},
        {"name": "endedAt", "type": "string|null", "required": false, "description": "RFC 3339 terminal timestamp."},
        {"name": "eventCount", "type": "integer", "required": true, "description": "Number of events recorded."},
        {"name": "redactedCount", "type": "integer", "required": true, "description": "Number of events with redaction."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:recorder-event:v1",
      "eeSchema": "ee.recorder.event.v1",
      "kind": "recorder_event",
      "title": "RecorderEvent",
      "description": "A single ordered event in a recorder run.",
      "type": "object",
      "required": [
        "schema",
        "eventId",
        "runId",
        "sequence",
        "eventType",
        "timestamp",
        "payloadBytes",
        "payloadAccepted",
        "redactionStatus",
        "redactionClasses",
        "placeholderCount",
        "redactedBytes",
        "eventHash",
        "chainStatus"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "eventId", "type": "string", "required": true, "description": "Stable event identifier."},
        {"name": "runId", "type": "string", "required": true, "description": "Recorder run identifier."},
        {"name": "sequence", "type": "integer", "required": true, "description": "Monotonic sequence within the run."},
        {"name": "eventType", "type": "string", "required": true, "description": "Stable event type."},
        {"name": "timestamp", "type": "string", "required": true, "description": "RFC 3339 event timestamp."},
        {"name": "payloadHash", "type": "string|null", "required": false, "description": "Hash of the associated payload, when stored."},
        {"name": "payloadBytes", "type": "integer", "required": true, "description": "Original accepted payload size in bytes."},
        {"name": "payloadAccepted", "type": "boolean", "required": true, "description": "Whether the payload passed size and redaction gates."},
        {"name": "redactionStatus", "type": "string", "required": true, "description": "Privacy state for the event."},
        {"name": "redactionClasses", "type": "array<string>", "required": true, "description": "Sorted redaction classes applied to the event payload."},
        {"name": "placeholderCount", "type": "integer", "required": true, "description": "Number of redaction placeholders applied."},
        {"name": "redactedBytes", "type": "integer", "required": true, "description": "Number of payload bytes redacted before hashing."},
        {"name": "previousEventHash", "type": "string|null", "required": false, "description": "Previous event hash used to link the append-only chain."},
        {"name": "eventHash", "type": "string", "required": true, "description": "BLAKE3 hash of canonical event metadata and previous hash."},
        {"name": "chainStatus", "type": "string", "required": true, "description": "Hash-chain state: root, linked, or missing_previous."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:recorder-payload:v1",
      "eeSchema": "ee.recorder.payload.v1",
      "kind": "recorder_payload",
      "title": "RecorderPayload",
      "description": "Metadata for stored recorder event payload content.",
      "type": "object",
      "required": [
        "schema",
        "payloadHash",
        "contentType",
        "byteSize",
        "storedAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "payloadHash", "type": "string", "required": true, "description": "Content-addressed payload hash."},
        {"name": "contentType", "type": "string", "required": true, "description": "Payload content class."},
        {"name": "byteSize", "type": "integer", "required": true, "description": "Original payload size in bytes."},
        {"name": "compressedSize", "type": "integer|null", "required": false, "description": "Compressed payload size in bytes."},
        {"name": "storedAt", "type": "string", "required": true, "description": "RFC 3339 storage timestamp."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:redaction-status:v1",
      "eeSchema": "ee.redaction.status.v1",
      "kind": "redaction_status",
      "title": "RedactionStatusSnapshot",
      "description": "Redaction accounting for recorder events and payloads.",
      "type": "object",
      "required": [
        "schema",
        "status",
        "redactionClasses",
        "placeholderCount",
        "redactedBytes"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "status", "type": "string", "required": true, "description": "Stable redaction status."},
        {"name": "redactionClasses", "type": "array<string>", "required": true, "description": "Sorted redaction classes present in the payload."},
        {"name": "placeholderCount", "type": "integer", "required": true, "description": "Number of placeholders inserted."},
        {"name": "redactedBytes", "type": "integer", "required": true, "description": "Number of bytes redacted."},
        {"name": "verifiedAt", "type": "string|null", "required": false, "description": "RFC 3339 verification timestamp."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:import-cursor:v1",
      "eeSchema": "ee.import.cursor.v1",
      "kind": "import_cursor",
      "title": "ImportCursor",
      "description": "Incremental import cursor for replayable connectors.",
      "type": "object",
      "required": [
        "schema",
        "sourceType",
        "sourceId",
        "itemsImported"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "sourceType", "type": "string", "required": true, "description": "Importer source type."},
        {"name": "sourceId", "type": "string", "required": true, "description": "Stable external source identity."},
        {"name": "lastImportedId", "type": "string|null", "required": false, "description": "Last external item imported."},
        {"name": "lastImportedAt", "type": "string|null", "required": false, "description": "RFC 3339 timestamp of the last imported item."},
        {"name": "itemsImported", "type": "integer", "required": true, "description": "Total imported item count."},
        {"name": "cursorState", "type": "string|null", "required": false, "description": "Opaque connector cursor state."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:recorder-import-plan:v1",
      "eeSchema": "ee.recorder.import_plan.v1",
      "kind": "recorder_import_plan",
      "title": "RecorderImportPlan",
      "description": "Read-only connector mapping plan for imported recorder runs and events.",
      "type": "object",
      "required": [
        "schema",
        "command",
        "dryRun",
        "source",
        "run",
        "summary",
        "mutations",
        "events",
        "warnings"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "command", "type": "string", "required": true, "description": "Stable command name: recorder import."},
        {"name": "dryRun", "type": "boolean", "required": true, "description": "Whether this plan avoids durable recorder writes."},
        {"name": "source", "type": "object", "required": true, "description": "Connector source identity and parser contract."},
        {"name": "run", "type": "object", "required": true, "description": "Planned imported recorder run metadata."},
        {"name": "summary", "type": "object", "required": true, "description": "Counts for discovered, mapped, rejected, and redacted events."},
        {"name": "mutations", "type": "array<object>", "required": true, "description": "Dry-run mutation descriptions that would be applied by a future writer."},
        {"name": "events", "type": "array<object>", "required": true, "description": "Deterministic mapped event plans without raw payload content."},
        {"name": "warnings", "type": "array<string>", "required": true, "description": "Non-fatal importer warnings and truncation notices."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:rationale-trace:v1",
      "eeSchema": "ee.rationale_trace.v1",
      "kind": "rationale_trace",
      "title": "RationaleTrace",
      "description": "Safe visible rationale summary with evidence links and redaction posture.",
      "type": "object",
      "required": [
        "schema",
        "traceId",
        "kind",
        "author",
        "summary",
        "posture",
        "confidenceBasisPoints",
        "visibility",
        "redactionStatus",
        "evidenceUris",
        "linkedMemoryIds",
        "linkedContextPackIds",
        "linkedRecorderRunIds",
        "linkedRecorderEventIds",
        "linkedCausalTraceIds",
        "supersedesTraceIds",
        "contradictedByTraceIds",
        "createdAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "traceId", "type": "string", "required": true, "description": "Stable rationale trace identifier."},
        {"name": "kind", "type": "string", "required": true, "description": "Visible rationale artifact kind."},
        {"name": "author", "type": "string", "required": true, "description": "Agent or human author identifier."},
        {"name": "summary", "type": "string", "required": true, "description": "Concise visible summary; never private chain-of-thought."},
        {"name": "posture", "type": "string", "required": true, "description": "Evidence posture: asserted, supported, contradicted, or unresolved."},
        {"name": "confidenceBasisPoints", "type": "integer", "required": true, "description": "Confidence from 0 to 10000 basis points."},
        {"name": "visibility", "type": "string", "required": true, "description": "Visibility/redaction posture for the summary."},
        {"name": "redactionStatus", "type": "string", "required": true, "description": "Redaction status applied before storage or rendering."},
        {"name": "evidenceUris", "type": "array<string>", "required": true, "description": "Canonical provenance URIs supporting the trace."},
        {"name": "linkedMemoryIds", "type": "array<string>", "required": true, "description": "Memory IDs linked to this rationale trace."},
        {"name": "linkedContextPackIds", "type": "array<string>", "required": true, "description": "Context pack IDs linked to this rationale trace."},
        {"name": "linkedRecorderRunIds", "type": "array<string>", "required": true, "description": "Recorder run IDs linked to this rationale trace."},
        {"name": "linkedRecorderEventIds", "type": "array<string>", "required": true, "description": "Recorder event IDs linked to this rationale trace."},
        {"name": "linkedCausalTraceIds", "type": "array<string>", "required": true, "description": "Causal trace IDs that reuse this rationale."},
        {"name": "supersedesTraceIds", "type": "array<string>", "required": true, "description": "Prior rationale trace IDs superseded by this trace."},
        {"name": "contradictedByTraceIds", "type": "array<string>", "required": true, "description": "Trace IDs that contradict this rationale."},
        {"name": "createdAt", "type": "string", "required": true, "description": "RFC 3339 creation timestamp."}
      ],
      "additionalProperties": false
    }
  ]
}
