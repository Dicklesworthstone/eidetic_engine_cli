{
  "schema": "ee.causal.schemas.v1",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:causal-exposure:v1",
      "eeSchema": "ee.causal.exposure.v1",
      "kind": "causal_exposure",
      "title": "CausalExposure",
      "description": "Exposure of a memory or artifact to an agent decision.",
      "type": "object",
      "required": [
        "schema",
        "exposureId",
        "artifactId",
        "artifactKind",
        "decisionId",
        "channel",
        "exposedAt",
        "evidenceIds"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "exposureId", "type": "string", "required": true, "description": "Stable exposure identifier."},
        {"name": "artifactId", "type": "string", "required": true, "description": "Exposed memory or artifact identifier."},
        {"name": "artifactKind", "type": "string", "required": true, "description": "Exposed artifact category."},
        {"name": "decisionId", "type": "string", "required": true, "description": "Decision that received the exposure."},
        {"name": "channel", "type": "string", "required": true, "description": "Exposure channel."},
        {"name": "exposedAt", "type": "string", "required": true, "description": "RFC 3339 exposure timestamp."},
        {"name": "rank", "type": "integer|null", "required": false, "description": "Rank or slot when exposure was ordered."},
        {"name": "policyId", "type": "string|null", "required": false, "description": "Policy active when exposed."},
        {"name": "contextPackId", "type": "string|null", "required": false, "description": "Context pack containing the exposure."},
        {"name": "traceId", "type": "string|null", "required": false, "description": "Trace linking related decisions."},
        {"name": "evidenceIds", "type": "array<string>", "required": true, "description": "Evidence supporting exposure capture."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:causal-decision-trace:v1",
      "eeSchema": "ee.causal.decision_trace.v1",
      "kind": "decision_trace",
      "title": "CausalDecisionTrace",
      "description": "Decision trace tying exposed artifacts to selected and rejected evidence.",
      "type": "object",
      "required": [
        "schema",
        "decisionId",
        "traceId",
        "plane",
        "decidedAt",
        "outcome",
        "agent",
        "exposedArtifactIds",
        "selectedArtifactIds",
        "rejectedArtifactIds",
        "rationale",
        "evidenceIds"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "decisionId", "type": "string", "required": true, "description": "Stable decision identifier."},
        {"name": "traceId", "type": "string", "required": true, "description": "Trace linking exposures and outcomes."},
        {"name": "plane", "type": "string", "required": true, "description": "Decision plane."},
        {"name": "decidedAt", "type": "string", "required": true, "description": "RFC 3339 decision timestamp."},
        {"name": "outcome", "type": "string", "required": true, "description": "How the decision treated exposed evidence."},
        {"name": "agent", "type": "string", "required": true, "description": "Agent, harness, or tool that made the decision."},
        {"name": "taskId", "type": "string|null", "required": false, "description": "Task or run associated with the decision."},
        {"name": "policyId", "type": "string|null", "required": false, "description": "Policy that governed the decision."},
        {"name": "exposedArtifactIds", "type": "array<string>", "required": true, "description": "Artifacts available to the decision."},
        {"name": "selectedArtifactIds", "type": "array<string>", "required": true, "description": "Artifacts actually used."},
        {"name": "rejectedArtifactIds", "type": "array<string>", "required": true, "description": "Artifacts rejected or ignored."},
        {"name": "rationale", "type": "string", "required": true, "description": "Decision rationale or explanation."},
        {"name": "evidenceIds", "type": "array<string>", "required": true, "description": "Evidence supporting the trace."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:causal-uplift-estimate:v1",
      "eeSchema": "ee.causal.uplift_estimate.v1",
      "kind": "uplift_estimate",
      "title": "UpliftEstimate",
      "description": "Bounded estimate of outcome change associated with an artifact exposure.",
      "type": "object",
      "required": [
        "schema",
        "estimateId",
        "artifactId",
        "decisionId",
        "baselineSuccessRate",
        "observedSuccessRate",
        "uplift",
        "direction",
        "confidence",
        "sampleSize",
        "evidenceStrength",
        "method",
        "exposureIds",
        "confounderIds",
        "estimatedAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "estimateId", "type": "string", "required": true, "description": "Stable uplift estimate identifier."},
        {"name": "artifactId", "type": "string", "required": true, "description": "Artifact whose influence is estimated."},
        {"name": "decisionId", "type": "string", "required": true, "description": "Decision or decision class being estimated."},
        {"name": "baselineSuccessRate", "type": "number", "required": true, "description": "Baseline outcome rate from 0.0 to 1.0."},
        {"name": "observedSuccessRate", "type": "number", "required": true, "description": "Observed outcome rate from 0.0 to 1.0."},
        {"name": "uplift", "type": "number", "required": true, "description": "Observed minus baseline rate from -1.0 to 1.0."},
        {"name": "direction", "type": "string", "required": true, "description": "Direction of the uplift estimate."},
        {"name": "confidence", "type": "number", "required": true, "description": "Confidence from 0.0 to 1.0."},
        {"name": "sampleSize", "type": "integer", "required": true, "description": "Number of observations used."},
        {"name": "evidenceStrength", "type": "string", "required": true, "description": "Strength of causal evidence."},
        {"name": "method", "type": "string", "required": true, "description": "Deterministic estimation method."},
        {"name": "exposureIds", "type": "array<string>", "required": true, "description": "Exposure records used by the estimate."},
        {"name": "confounderIds", "type": "array<string>", "required": true, "description": "Known confounders considered."},
        {"name": "estimatedAt", "type": "string", "required": true, "description": "RFC 3339 estimate timestamp."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:causal-confounder:v1",
      "eeSchema": "ee.causal.confounder.v1",
      "kind": "confounder",
      "title": "CausalConfounder",
      "description": "Alternative explanation that can weaken or block causal claims.",
      "type": "object",
      "required": [
        "schema",
        "confounderId",
        "kind",
        "description",
        "severity",
        "mitigation",
        "affectedArtifactIds",
        "affectedDecisionIds",
        "evidenceIds"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "confounderId", "type": "string", "required": true, "description": "Stable confounder identifier."},
        {"name": "kind", "type": "string", "required": true, "description": "Confounder class."},
        {"name": "description", "type": "string", "required": true, "description": "Why this can explain apparent uplift."},
        {"name": "severity", "type": "number", "required": true, "description": "Severity from 0.0 to 1.0."},
        {"name": "mitigation", "type": "string", "required": true, "description": "How to control or account for the confounder."},
        {"name": "affectedArtifactIds", "type": "array<string>", "required": true, "description": "Artifacts affected by this confounder."},
        {"name": "affectedDecisionIds", "type": "array<string>", "required": true, "description": "Decisions affected by this confounder."},
        {"name": "evidenceIds", "type": "array<string>", "required": true, "description": "Evidence supporting the confounder."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:causal-promotion-plan:v1",
      "eeSchema": "ee.causal.promotion_plan.v1",
      "kind": "promotion_plan",
      "title": "PromotionPlan",
      "description": "Dry-run-first plan for promotion, demotion, archive, or quarantine decisions.",
      "type": "object",
      "required": [
        "schema",
        "planId",
        "artifactId",
        "action",
        "status",
        "evidenceStrength",
        "minimumUplift",
        "estimatedUplift",
        "requiredEvidenceIds",
        "blockingConfounderIds",
        "dryRunFirst",
        "auditIds",
        "createdAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "planId", "type": "string", "required": true, "description": "Stable promotion plan identifier."},
        {"name": "artifactId", "type": "string", "required": true, "description": "Artifact targeted by the plan."},
        {"name": "action", "type": "string", "required": true, "description": "Planned memory posture action."},
        {"name": "status", "type": "string", "required": true, "description": "Promotion plan lifecycle status."},
        {"name": "evidenceStrength", "type": "string", "required": true, "description": "Evidence strength required by the plan."},
        {"name": "minimumUplift", "type": "number", "required": true, "description": "Minimum uplift threshold from -1.0 to 1.0."},
        {"name": "estimatedUplift", "type": "number", "required": true, "description": "Current estimated uplift from -1.0 to 1.0."},
        {"name": "requiredEvidenceIds", "type": "array<string>", "required": true, "description": "Evidence required before applying the plan."},
        {"name": "blockingConfounderIds", "type": "array<string>", "required": true, "description": "Confounders blocking promotion."},
        {"name": "dryRunFirst", "type": "boolean", "required": true, "description": "Whether dry-run verification is required before mutation."},
        {"name": "auditIds", "type": "array<string>", "required": true, "description": "Audit records attached to the plan."},
        {"name": "createdAt", "type": "string", "required": true, "description": "RFC 3339 creation timestamp."}
      ],
      "additionalProperties": false
    }
  ]
}
