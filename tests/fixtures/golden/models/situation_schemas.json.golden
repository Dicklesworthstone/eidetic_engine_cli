{
  "schema": "ee.situation.schemas.v1",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:situation:v1",
      "eeSchema": "ee.situation.v1",
      "kind": "situation",
      "title": "Situation",
      "description": "Normalized task situation record used for routing and retrieval.",
      "type": "object",
      "required": [
        "schema",
        "situationId",
        "category",
        "taskSignatureId",
        "title",
        "summary",
        "sourceTextHash",
        "confidence",
        "confidenceScore",
        "evidenceIds",
        "linkCount",
        "createdAt",
        "updatedAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "situationId", "type": "string", "required": true, "description": "Stable situation identifier."},
        {"name": "category", "type": "string", "required": true, "description": "Stable situation category."},
        {"name": "taskSignatureId", "type": "string", "required": true, "description": "Task signature this situation was derived from."},
        {"name": "title", "type": "string", "required": true, "description": "Short situation title."},
        {"name": "summary", "type": "string", "required": true, "description": "Short situation summary."},
        {"name": "sourceTextHash", "type": "string", "required": true, "description": "Hash of the normalized task text used to classify the situation."},
        {"name": "confidence", "type": "string", "required": true, "description": "Classification confidence band."},
        {"name": "confidenceScore", "type": "number", "required": true, "description": "Bounded confidence score from 0.0 to 1.0."},
        {"name": "evidenceIds", "type": "array<string>", "required": true, "description": "Feature evidence identifiers supporting this situation."},
        {"name": "linkCount", "type": "integer", "required": true, "description": "Number of known links to other situations."},
        {"name": "createdAt", "type": "string", "required": true, "description": "RFC 3339 creation timestamp."},
        {"name": "updatedAt", "type": "string", "required": true, "description": "RFC 3339 update timestamp."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:task-signature:v1",
      "eeSchema": "ee.task_signature.v1",
      "kind": "task_signature",
      "title": "TaskSignature",
      "description": "Deterministic signature extracted from task text and repository context.",
      "type": "object",
      "required": [
        "schema",
        "signatureId",
        "normalizedTextHash",
        "languageSet",
        "commandFamilies",
        "pathGlobs",
        "riskTags",
        "featureCount",
        "createdAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "signatureId", "type": "string", "required": true, "description": "Stable task signature identifier."},
        {"name": "normalizedTextHash", "type": "string", "required": true, "description": "Hash of normalized task text."},
        {"name": "repositoryFingerprint", "type": "string|null", "required": false, "description": "Optional repository fingerprint used for routing."},
        {"name": "languageSet", "type": "array<string>", "required": true, "description": "Sorted language identifiers detected for the task."},
        {"name": "commandFamilies", "type": "array<string>", "required": true, "description": "Sorted command families mentioned or inferred."},
        {"name": "pathGlobs", "type": "array<string>", "required": true, "description": "Sorted path globs relevant to the task."},
        {"name": "riskTags", "type": "array<string>", "required": true, "description": "Sorted risk tags derived from task and repository context."},
        {"name": "featureCount", "type": "integer", "required": true, "description": "Number of feature evidence records supporting this signature."},
        {"name": "createdAt", "type": "string", "required": true, "description": "RFC 3339 creation timestamp."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:situation-feature-evidence:v1",
      "eeSchema": "ee.situation.feature_evidence.v1",
      "kind": "feature_evidence",
      "title": "FeatureEvidence",
      "description": "Evidence feature contributing to a task signature or route.",
      "type": "object",
      "required": [
        "schema",
        "evidenceId",
        "signatureId",
        "featureName",
        "featureType",
        "value",
        "weight",
        "source",
        "observedAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "evidenceId", "type": "string", "required": true, "description": "Stable feature evidence identifier."},
        {"name": "signatureId", "type": "string", "required": true, "description": "Task signature identifier."},
        {"name": "featureName", "type": "string", "required": true, "description": "Stable feature name."},
        {"name": "featureType", "type": "string", "required": true, "description": "Feature extraction type."},
        {"name": "value", "type": "string", "required": true, "description": "Captured feature value."},
        {"name": "weight", "type": "number", "required": true, "description": "Bounded feature weight from 0.0 to 1.0."},
        {"name": "source", "type": "string", "required": true, "description": "Feature source, such as text, repository, command history, or import."},
        {"name": "observedAt", "type": "string", "required": true, "description": "RFC 3339 observation timestamp."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:situation-routing-decision:v1",
      "eeSchema": "ee.situation.routing_decision.v1",
      "kind": "routing_decision",
      "title": "RoutingDecision",
      "description": "Explainable routing decision derived from a situation.",
      "type": "object",
      "required": [
        "schema",
        "routingId",
        "situationId",
        "surface",
        "confidence",
        "confidenceScore",
        "procedureCandidateIds",
        "fixtureIds",
        "tripwireCandidateIds",
        "replayPolicy",
        "reasons",
        "createdAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "routingId", "type": "string", "required": true, "description": "Stable routing decision identifier."},
        {"name": "situationId", "type": "string", "required": true, "description": "Routed situation identifier."},
        {"name": "surface", "type": "string", "required": true, "description": "Routing surface being selected."},
        {"name": "confidence", "type": "string", "required": true, "description": "Routing confidence band."},
        {"name": "confidenceScore", "type": "number", "required": true, "description": "Bounded routing confidence score from 0.0 to 1.0."},
        {"name": "selectedProfile", "type": "string|null", "required": false, "description": "Selected profile for the target surface."},
        {"name": "retrievalProfile", "type": "string|null", "required": false, "description": "Context retrieval profile selected for this situation."},
        {"name": "preflightProfile", "type": "string|null", "required": false, "description": "Preflight profile selected for this situation."},
        {"name": "procedureCandidateIds", "type": "array<string>", "required": true, "description": "Candidate procedure identifiers selected by routing."},
        {"name": "fixtureIds", "type": "array<string>", "required": true, "description": "Fixture identifiers selected by routing."},
        {"name": "tripwireCandidateIds", "type": "array<string>", "required": true, "description": "Candidate tripwire identifiers selected by routing."},
        {"name": "replayPolicy", "type": "string", "required": true, "description": "Counterfactual replay eligibility policy."},
        {"name": "reasons", "type": "array<string>", "required": true, "description": "Stable reasons explaining the routing decision."},
        {"name": "createdAt", "type": "string", "required": true, "description": "RFC 3339 creation timestamp."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:situation-link:v1",
      "eeSchema": "ee.situation.link.v1",
      "kind": "situation_link",
      "title": "SituationLink",
      "description": "Explainable relation between two situations.",
      "type": "object",
      "required": [
        "schema",
        "linkId",
        "sourceSituationId",
        "targetSituationId",
        "relation",
        "directed",
        "confidence",
        "confidenceScore",
        "evidenceIds",
        "createdAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "linkId", "type": "string", "required": true, "description": "Stable situation-link identifier."},
        {"name": "sourceSituationId", "type": "string", "required": true, "description": "Source situation identifier."},
        {"name": "targetSituationId", "type": "string", "required": true, "description": "Target situation identifier."},
        {"name": "relation", "type": "string", "required": true, "description": "Stable situation-link relation."},
        {"name": "directed", "type": "boolean", "required": true, "description": "Whether link direction is meaningful."},
        {"name": "confidence", "type": "string", "required": true, "description": "Link confidence band."},
        {"name": "confidenceScore", "type": "number", "required": true, "description": "Bounded link confidence score from 0.0 to 1.0."},
        {"name": "evidenceIds", "type": "array<string>", "required": true, "description": "Evidence identifiers supporting the link."},
        {"name": "createdAt", "type": "string", "required": true, "description": "RFC 3339 creation timestamp."}
      ],
      "additionalProperties": false
    }
  ]
}
