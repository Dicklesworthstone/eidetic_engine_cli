{
  "schema": "ee.learning.schemas.v1",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:learning-question:v1",
      "eeSchema": "ee.learning.question.v1",
      "kind": "learning_question",
      "title": "LearningQuestion",
      "description": "High-value uncertainty that could change a memory decision.",
      "type": "object",
      "required": [
        "schema",
        "questionId",
        "topic",
        "prompt",
        "status",
        "targetArtifactIds",
        "decisionImpact",
        "priority",
        "uncertainty",
        "expectedValue",
        "evidenceIds",
        "createdAt",
        "updatedAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "questionId", "type": "string", "required": true, "description": "Stable question identifier."},
        {"name": "topic", "type": "string", "required": true, "description": "Question topic or subsystem."},
        {"name": "prompt", "type": "string", "required": true, "description": "Concrete uncertainty to resolve."},
        {"name": "status", "type": "string", "required": true, "description": "Question lifecycle status."},
        {"name": "targetArtifactIds", "type": "array<string>", "required": true, "description": "Artifacts whose treatment could change after resolving the question."},
        {"name": "decisionImpact", "type": "string", "required": true, "description": "Decision that could change if uncertainty is reduced."},
        {"name": "priority", "type": "integer", "required": true, "description": "Priority from 0 to 100."},
        {"name": "uncertainty", "type": "number", "required": true, "description": "Current uncertainty estimate from 0.0 to 1.0."},
        {"name": "expectedValue", "type": "number", "required": true, "description": "Expected value of reducing the uncertainty from 0.0 to 1.0."},
        {"name": "evidenceIds", "type": "array<string>", "required": true, "description": "Evidence identifiers supporting the question."},
        {"name": "createdAt", "type": "string", "required": true, "description": "RFC 3339 creation timestamp."},
        {"name": "updatedAt", "type": "string", "required": true, "description": "RFC 3339 update timestamp."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:learning-uncertainty-estimate:v1",
      "eeSchema": "ee.learning.uncertainty_estimate.v1",
      "kind": "uncertainty_estimate",
      "title": "UncertaintyEstimate",
      "description": "Quantified uncertainty and confidence for a learning target.",
      "type": "object",
      "required": [
        "schema",
        "estimateId",
        "questionId",
        "targetId",
        "targetKind",
        "uncertainty",
        "confidence",
        "sampleSize",
        "method",
        "evidenceIds",
        "estimatedAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "estimateId", "type": "string", "required": true, "description": "Stable estimate identifier."},
        {"name": "questionId", "type": "string", "required": true, "description": "Parent learning question identifier."},
        {"name": "targetId", "type": "string", "required": true, "description": "Artifact or decision being estimated."},
        {"name": "targetKind", "type": "string", "required": true, "description": "Target artifact category."},
        {"name": "uncertainty", "type": "number", "required": true, "description": "Uncertainty from 0.0 to 1.0."},
        {"name": "confidence", "type": "number", "required": true, "description": "Confidence from 0.0 to 1.0."},
        {"name": "sampleSize", "type": "integer", "required": true, "description": "Number of observations or retrievals used."},
        {"name": "method", "type": "string", "required": true, "description": "Deterministic estimation method."},
        {"name": "evidenceIds", "type": "array<string>", "required": true, "description": "Evidence identifiers used by the estimate."},
        {"name": "estimatedAt", "type": "string", "required": true, "description": "RFC 3339 estimate timestamp."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:learning-experiment:v1",
      "eeSchema": "ee.learning.experiment.v1",
      "kind": "learning_experiment",
      "title": "LearningExperiment",
      "description": "Safe dry-run-first experiment proposed to reduce uncertainty.",
      "type": "object",
      "required": [
        "schema",
        "experimentId",
        "questionId",
        "title",
        "hypothesis",
        "status",
        "safetyBoundary",
        "expectedValue",
        "attentionBudgetTokens",
        "maxRuntimeSeconds",
        "dryRunFirst",
        "stopCondition",
        "affectedDecisionIds",
        "proposedAt"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "experimentId", "type": "string", "required": true, "description": "Stable experiment identifier."},
        {"name": "questionId", "type": "string", "required": true, "description": "Learning question identifier."},
        {"name": "title", "type": "string", "required": true, "description": "Short experiment title."},
        {"name": "hypothesis", "type": "string", "required": true, "description": "Hypothesis the experiment can test."},
        {"name": "status", "type": "string", "required": true, "description": "Experiment lifecycle status."},
        {"name": "safetyBoundary", "type": "string", "required": true, "description": "Boundary that must be honored before running the experiment."},
        {"name": "expectedValue", "type": "number", "required": true, "description": "Expected value of the experiment from 0.0 to 1.0."},
        {"name": "attentionBudgetTokens", "type": "integer", "required": true, "description": "Maximum attention budget the experiment may consume."},
        {"name": "maxRuntimeSeconds", "type": "integer", "required": true, "description": "Maximum wall-clock runtime budget."},
        {"name": "dryRunFirst", "type": "boolean", "required": true, "description": "Whether dry-run execution is required before mutation."},
        {"name": "stopCondition", "type": "string", "required": true, "description": "Condition that stops the experiment."},
        {"name": "affectedDecisionIds", "type": "array<string>", "required": true, "description": "Decision identifiers the experiment may influence."},
        {"name": "proposedAt", "type": "string", "required": true, "description": "RFC 3339 proposal timestamp."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:learning-observation:v1",
      "eeSchema": "ee.learning.observation.v1",
      "kind": "learning_observation",
      "title": "LearningObservation",
      "description": "Evidence observed while running or reviewing a learning experiment.",
      "type": "object",
      "required": [
        "schema",
        "observationId",
        "experimentId",
        "observedAt",
        "observer",
        "signal",
        "measurementName",
        "evidenceIds",
        "redactionStatus"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "observationId", "type": "string", "required": true, "description": "Stable observation identifier."},
        {"name": "experimentId", "type": "string", "required": true, "description": "Learning experiment identifier."},
        {"name": "observedAt", "type": "string", "required": true, "description": "RFC 3339 observation timestamp."},
        {"name": "observer", "type": "string", "required": true, "description": "Agent, harness, or tool observer."},
        {"name": "signal", "type": "string", "required": true, "description": "Observation signal direction."},
        {"name": "measurementName", "type": "string", "required": true, "description": "Measured quantity name."},
        {"name": "measurementValue", "type": "number|null", "required": false, "description": "Measured quantity value when numeric."},
        {"name": "evidenceIds", "type": "array<string>", "required": true, "description": "Evidence identifiers captured with the observation."},
        {"name": "note", "type": "string|null", "required": false, "description": "Human or agent observation note."},
        {"name": "redactionStatus", "type": "string", "required": true, "description": "Redaction state of evidence."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:experiment-outcome:v1",
      "eeSchema": "ee.learning.experiment_outcome.v1",
      "kind": "experiment_outcome",
      "title": "ExperimentOutcome",
      "description": "Auditable confirmed, rejected, inconclusive, or unsafe experiment result.",
      "type": "object",
      "required": [
        "schema",
        "outcomeId",
        "experimentId",
        "status",
        "closedAt",
        "decisionImpact",
        "confidenceDelta",
        "priorityDelta",
        "promotedArtifactIds",
        "demotedArtifactIds",
        "safetyNotes",
        "auditIds"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "outcomeId", "type": "string", "required": true, "description": "Stable outcome identifier."},
        {"name": "experimentId", "type": "string", "required": true, "description": "Learning experiment identifier."},
        {"name": "status", "type": "string", "required": true, "description": "Outcome status."},
        {"name": "closedAt", "type": "string", "required": true, "description": "RFC 3339 closure timestamp."},
        {"name": "decisionImpact", "type": "string", "required": true, "description": "Decision impact observed after closing the experiment."},
        {"name": "confidenceDelta", "type": "number", "required": true, "description": "Change in confidence from -1.0 to 1.0."},
        {"name": "priorityDelta", "type": "integer", "required": true, "description": "Change applied to future learning priority."},
        {"name": "promotedArtifactIds", "type": "array<string>", "required": true, "description": "Artifacts confirmed by the outcome."},
        {"name": "demotedArtifactIds", "type": "array<string>", "required": true, "description": "Artifacts weakened or rejected by the outcome."},
        {"name": "safetyNotes", "type": "array<string>", "required": true, "description": "Safety notes, unsafe findings, or stop reasons."},
        {"name": "auditIds", "type": "array<string>", "required": true, "description": "Audit records for outcome closure and any mutations."}
      ],
      "additionalProperties": false
    }
  ]
}
