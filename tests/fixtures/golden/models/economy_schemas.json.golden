{
  "schema": "ee.economy.schemas.v1",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:economy-utility-value:v1",
      "eeSchema": "ee.economy.utility_value.v1",
      "kind": "utility_value",
      "title": "UtilityValue",
      "description": "Evidence-backed value estimate for surfacing an artifact.",
      "type": "object",
      "required": [
        "schema",
        "score",
        "retrievalCount",
        "successCount",
        "falseAlarmCount",
        "projectedUtility",
        "confidence",
        "effective",
        "falseAlarmRate"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "score", "type": "number", "required": true, "description": "Raw utility score from 0.0 to 1.0."},
        {"name": "retrievalCount", "type": "integer", "required": true, "description": "Times the artifact was retrieved."},
        {"name": "successCount", "type": "integer", "required": true, "description": "Times retrieval contributed to a successful outcome."},
        {"name": "falseAlarmCount", "type": "integer", "required": true, "description": "Times retrieval wasted attention or produced a false alarm."},
        {"name": "projectedUtility", "type": "number", "required": true, "description": "Projected future utility based on trend evidence."},
        {"name": "confidence", "type": "number", "required": true, "description": "Confidence in the utility estimate from 0.0 to 1.0."},
        {"name": "effective", "type": "number", "required": true, "description": "Utility score adjusted by confidence."},
        {"name": "falseAlarmRate", "type": "number", "required": true, "description": "False alarms divided by retrieval count."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:economy-attention-cost:v1",
      "eeSchema": "ee.economy.attention_cost.v1",
      "kind": "attention_cost",
      "title": "AttentionCost",
      "description": "Token and cognitive cost estimate for surfacing an artifact.",
      "type": "object",
      "required": [
        "schema",
        "tokenCost",
        "cognitiveLoad",
        "relevanceDecay",
        "contextSwitchCost",
        "displacementCost",
        "totalCost"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "tokenCost", "type": "integer", "required": true, "description": "Token cost of surfacing the artifact."},
        {"name": "cognitiveLoad", "type": "number", "required": true, "description": "Estimated cognitive load from 0.0 to 1.0."},
        {"name": "relevanceDecay", "type": "number", "required": true, "description": "Relevance decay since last use from 0.0 to 1.0."},
        {"name": "contextSwitchCost", "type": "number", "required": true, "description": "Cost of switching context to use the artifact."},
        {"name": "displacementCost", "type": "number", "required": true, "description": "Opportunity cost of displacing other artifacts."},
        {"name": "totalCost", "type": "number", "required": true, "description": "Weighted aggregate attention cost."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:economy-attention-budget:v1",
      "eeSchema": "ee.economy.attention_budget.v1",
      "kind": "attention_budget",
      "title": "AttentionBudgetAllocation",
      "description": "Deterministic token allocation for context and situation attention profiles.",
      "type": "object",
      "required": [
        "schema",
        "totalTokens",
        "usedTokens",
        "contextProfile",
        "situationProfile",
        "retrievalTokens",
        "evidenceTokens",
        "procedureTokens",
        "riskReserveTokens",
        "maintenanceTokens",
        "reserveRatio",
        "maxItems",
        "attentionCost",
        "reasons"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "totalTokens", "type": "integer", "required": true, "description": "Total attention token budget being allocated."},
        {"name": "usedTokens", "type": "integer", "required": true, "description": "Allocated tokens across all attention buckets."},
        {"name": "contextProfile", "type": "string", "required": true, "description": "Context packing profile used as the base allocation."},
        {"name": "situationProfile", "type": "string", "required": true, "description": "Situation routing profile used as the adjustment."},
        {"name": "retrievalTokens", "type": "integer", "required": true, "description": "Tokens reserved for retrieved memories and search results."},
        {"name": "evidenceTokens", "type": "integer", "required": true, "description": "Tokens reserved for provenance, proof, and supporting evidence."},
        {"name": "procedureTokens", "type": "integer", "required": true, "description": "Tokens reserved for procedural guidance."},
        {"name": "riskReserveTokens", "type": "integer", "required": true, "description": "Tokens held back for rare high-severity or low-confidence cases."},
        {"name": "maintenanceTokens", "type": "integer", "required": true, "description": "Tokens reserved for maintenance/degradation notices."},
        {"name": "reserveRatio", "type": "number", "required": true, "description": "Risk reserve as a fraction of total tokens."},
        {"name": "maxItems", "type": "integer", "required": true, "description": "Maximum surfaced item count for the allocation."},
        {"name": "attentionCost", "type": "object", "required": true, "description": "Derived attention cost for surfaced tokens."},
        {"name": "reasons", "type": "array<string>", "required": true, "description": "Deterministic explanation of the selected allocation."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:economy-risk-reserve:v1",
      "eeSchema": "ee.economy.risk_reserve.v1",
      "kind": "risk_reserve",
      "title": "RiskReserve",
      "description": "Reserved attention budget for tail-risk coverage and fallback evidence.",
      "type": "object",
      "required": [
        "schema",
        "tokenBudget",
        "memorySlots",
        "utilization",
        "coveredRisks",
        "minLevel",
        "maxLevel",
        "availableTokens",
        "availableSlots",
        "isDepleted",
        "hasExcess"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "tokenBudget", "type": "integer", "required": true, "description": "Token budget reserved for tail-risk coverage."},
        {"name": "memorySlots", "type": "integer", "required": true, "description": "Artifact slots reserved for critical fallback information."},
        {"name": "utilization", "type": "number", "required": true, "description": "Reserve utilization from 0.0 to 1.0."},
        {"name": "coveredRisks", "type": "array<string>", "required": true, "description": "Risk categories covered by the reserve."},
        {"name": "minLevel", "type": "number", "required": true, "description": "Minimum reserve level before depletion warnings."},
        {"name": "maxLevel", "type": "number", "required": true, "description": "Maximum reserve level before excess capacity can be released."},
        {"name": "availableTokens", "type": "integer", "required": true, "description": "Token budget still available in the reserve."},
        {"name": "availableSlots", "type": "integer", "required": true, "description": "Artifact slots still available in the reserve."},
        {"name": "isDepleted", "type": "boolean", "required": true, "description": "Whether reserve capacity is depleted."},
        {"name": "hasExcess", "type": "boolean", "required": true, "description": "Whether reserve capacity is above its target maximum."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:economy-tail-risk-reserve-rule:v1",
      "eeSchema": "ee.economy.tail_risk_reserve_rule.v1",
      "kind": "tail_risk_reserve_rule",
      "title": "TailRiskReserveRule",
      "description": "Rule that protects rare high-severity warnings and procedures from popularity-only demotion.",
      "type": "object",
      "required": [
        "schema",
        "ruleId",
        "artifactId",
        "artifactKind",
        "severity",
        "riskCategory",
        "supportingEvidenceCount",
        "historicalTriggerCount",
        "retrievalCount",
        "falseAlarmCount",
        "falseAlarmRate",
        "popularityScore",
        "utilityScore",
        "rareSignal",
        "highSeverity",
        "protectableArtifact",
        "demotionAction",
        "blocksPopularityDemotion",
        "requiresManualReview",
        "reserveTokens",
        "reserveSlots",
        "reasons"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "ruleId", "type": "string", "required": true, "description": "Stable reserve rule identifier."},
        {"name": "artifactId", "type": "string", "required": true, "description": "Artifact protected or released by the rule."},
        {"name": "artifactKind", "type": "string", "required": true, "description": "Artifact kind: warning, procedure, tripwire, memory, or other."},
        {"name": "severity", "type": "string", "required": true, "description": "Tail-risk severity assigned to the artifact."},
        {"name": "riskCategory", "type": "string", "required": true, "description": "Risk category covered."},
        {"name": "supportingEvidenceCount", "type": "integer", "required": true, "description": "Evidence items that justify protection."},
        {"name": "historicalTriggerCount", "type": "integer", "required": true, "description": "Observed historical triggers for the tail risk."},
        {"name": "retrievalCount", "type": "integer", "required": true, "description": "Times the artifact was retrieved."},
        {"name": "falseAlarmCount", "type": "integer", "required": true, "description": "Times the artifact produced a false alarm."},
        {"name": "falseAlarmRate", "type": "number", "required": true, "description": "False alarms divided by retrieval count."},
        {"name": "popularityScore", "type": "number", "required": true, "description": "Observed popularity from 0.0 to 1.0."},
        {"name": "utilityScore", "type": "number", "required": true, "description": "Current utility score from 0.0 to 1.0."},
        {"name": "rareSignal", "type": "boolean", "required": true, "description": "Whether the artifact is rare enough for reserve protection."},
        {"name": "highSeverity", "type": "boolean", "required": true, "description": "Whether severity is high or critical."},
        {"name": "protectableArtifact", "type": "boolean", "required": true, "description": "Whether the artifact kind is a warning or procedure."},
        {"name": "demotionAction", "type": "string", "required": true, "description": "Deterministic demotion decision."},
        {"name": "blocksPopularityDemotion", "type": "boolean", "required": true, "description": "Whether popularity-only demotion is blocked."},
        {"name": "requiresManualReview", "type": "boolean", "required": true, "description": "Whether false-alarm pressure requires manual review."},
        {"name": "reserveTokens", "type": "integer", "required": true, "description": "Tokens retained in reserve while demotion is blocked."},
        {"name": "reserveSlots", "type": "integer", "required": true, "description": "Artifact slots retained in reserve while demotion is blocked."},
        {"name": "reasons", "type": "array<string>", "required": true, "description": "Deterministic explanation of the reserve decision."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:economy-maintenance-debt:v1",
      "eeSchema": "ee.economy.maintenance_debt.v1",
      "kind": "maintenance_debt",
      "title": "MaintenanceDebt",
      "description": "Deferred memory maintenance work that degrades retrieval quality.",
      "type": "object",
      "required": [
        "schema",
        "staleMemories",
        "orphanedLinks",
        "pendingConsolidations",
        "indexDrift",
        "unvalidatedRules",
        "daysSinceSweep",
        "debtScore",
        "level",
        "isUrgent",
        "isHealthy"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "staleMemories", "type": "integer", "required": true, "description": "Stale memories needing review."},
        {"name": "orphanedLinks", "type": "integer", "required": true, "description": "Orphaned links needing cleanup."},
        {"name": "pendingConsolidations", "type": "integer", "required": true, "description": "Consolidation candidates waiting for review."},
        {"name": "indexDrift", "type": "integer", "required": true, "description": "Index entries out of sync."},
        {"name": "unvalidatedRules", "type": "integer", "required": true, "description": "Procedural rules that still lack validation evidence."},
        {"name": "daysSinceSweep", "type": "integer", "required": true, "description": "Days since the last full maintenance sweep."},
        {"name": "debtScore", "type": "number", "required": true, "description": "Overall maintenance debt score from 0.0 to 1.0."},
        {"name": "level", "type": "string", "required": true, "description": "Categorical maintenance debt level."},
        {"name": "isUrgent", "type": "boolean", "required": true, "description": "Whether maintenance should be prioritized immediately."},
        {"name": "isHealthy", "type": "boolean", "required": true, "description": "Whether maintenance debt is within the healthy range."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:economy-recommendation:v1",
      "eeSchema": "ee.economy.recommendation.v1",
      "kind": "economy_recommendation",
      "title": "EconomyRecommendation",
      "description": "Recommended action to improve utility, reserves, or maintenance debt.",
      "type": "object",
      "required": [
        "schema",
        "id",
        "type",
        "priority",
        "adjustedPriority",
        "title",
        "description",
        "expectedImpact",
        "effort",
        "automatable"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "id", "type": "string", "required": true, "description": "Stable recommendation identifier."},
        {"name": "type", "type": "string", "required": true, "description": "Recommendation type."},
        {"name": "priority", "type": "integer", "required": true, "description": "Base priority from 0 to 100."},
        {"name": "adjustedPriority", "type": "integer", "required": true, "description": "Priority adjusted by expected impact and effort."},
        {"name": "title", "type": "string", "required": true, "description": "Human-readable recommendation title."},
        {"name": "description", "type": "string", "required": true, "description": "Recommendation details."},
        {"name": "expectedImpact", "type": "string", "required": true, "description": "Expected impact level."},
        {"name": "effort", "type": "string", "required": true, "description": "Estimated implementation effort."},
        {"name": "automatable", "type": "boolean", "required": true, "description": "Whether action may be automated."},
        {"name": "suggestedCommand", "type": "string|null", "required": false, "description": "Suggested CLI command when automation is safe."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:economy-report:v1",
      "eeSchema": "ee.economy.report.v1",
      "kind": "economy_report",
      "title": "EconomyReport",
      "description": "Snapshot report over utility, attention cost, reserves, debt, and recommendations.",
      "type": "object",
      "required": [
        "schema",
        "generatedAt",
        "healthScore",
        "riskReserve",
        "maintenanceDebt",
        "aggregateUtility",
        "recommendationCount",
        "recommendations"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "generatedAt", "type": "string", "required": true, "description": "RFC 3339 report timestamp."},
        {"name": "healthScore", "type": "number", "required": true, "description": "Overall economy health score."},
        {"name": "riskReserve", "type": "object", "required": true, "description": "Current risk reserve status."},
        {"name": "maintenanceDebt", "type": "object", "required": true, "description": "Current maintenance debt status."},
        {"name": "aggregateUtility", "type": "object", "required": true, "description": "Aggregate utility metrics across artifacts."},
        {"name": "recommendationCount", "type": "integer", "required": true, "description": "Number of active recommendations."},
        {"name": "recommendations", "type": "array<object>", "required": true, "description": "Active economy recommendations sorted by priority."}
      ],
      "additionalProperties": false
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "urn:ee:schema:economy-simulation:v1",
      "eeSchema": "ee.economy.simulation.v1",
      "kind": "economy_simulation",
      "title": "EconomySimulationReport",
      "description": "Report-only comparison of alternate attention budgets without changing ranking state.",
      "type": "object",
      "required": [
        "schema",
        "generatedAt",
        "dryRun",
        "mutationStatus",
        "baselineBudgetTokens",
        "contextProfile",
        "situationProfile",
        "rankingStateHashBefore",
        "rankingStateHashAfter",
        "rankingStateUnchanged",
        "summary",
        "scenarios",
        "explanations"
      ],
      "fields": [
        {"name": "schema", "type": "string", "required": true, "description": "Schema identifier."},
        {"name": "generatedAt", "type": "string", "required": true, "description": "RFC 3339 simulation timestamp."},
        {"name": "dryRun", "type": "boolean", "required": true, "description": "Always true for simulation output."},
        {"name": "mutationStatus", "type": "string", "required": true, "description": "Mutation state; simulation reports not_applied."},
        {"name": "baselineBudgetTokens", "type": "integer", "required": true, "description": "Baseline attention budget used for delta comparisons."},
        {"name": "contextProfile", "type": "string", "required": true, "description": "Context attention profile used by every scenario."},
        {"name": "situationProfile", "type": "string", "required": true, "description": "Situation attention profile used by every scenario."},
        {"name": "rankingStateHashBefore", "type": "string", "required": true, "description": "Hash of ranking inputs before simulation."},
        {"name": "rankingStateHashAfter", "type": "string", "required": true, "description": "Hash of ranking inputs after simulation."},
        {"name": "rankingStateUnchanged", "type": "boolean", "required": true, "description": "Whether before and after ranking hashes match."},
        {"name": "summary", "type": "object", "required": true, "description": "Best budget, baseline delta, and no-mutation evidence."},
        {"name": "scenarios", "type": "array<object>", "required": true, "description": "Budget scenarios with scores, allocations, and rankings."},
        {"name": "explanations", "type": "array<string>", "required": true, "description": "Deterministic explanation of simulation assumptions."}
      ],
      "additionalProperties": false
    }
  ]
}
