{
  "schema": "ee.failure_mode_fixture.v1",
  "code": "stale_validity_filtered",
  "introduced_by": {
    "bead": "bd-17c65.10.6",
    "epic_letter": "J"
  },
  "surfaces": [
    "search"
  ],
  "severity": "low",
  "repair_present": true,
  "trigger": {
    "description": "Search encounters an indexed memory whose validity-window metadata no longer matches the database row and excludes it unless stale memories are explicitly requested.",
    "setup_commands": [
      "ee init --workspace .",
      "ee remember 'J6 stale validity marker.' --workspace . --valid-to 2000-01-01T00:00:00Z --json",
      "ee diag memory-validity --workspace . --memory-id <memory-id> --clear-valid-to --json"
    ],
    "invocation": "ee search 'stale validity marker' --workspace . --json"
  },
  "expected_emission": {
    "code": "stale_validity_filtered",
    "severity": "low",
    "message_contains": [
      "stale",
      "validity_status"
    ],
    "repair_contains": "--include-stale"
  }
}
