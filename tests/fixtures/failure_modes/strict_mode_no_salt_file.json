{
  "schema": "ee.failure_mode_fixture.v1",
  "code": "strict_mode_no_salt_file",
  "introduced_by": {
    "bead": "bd-17c65.13.6",
    "epic_letter": "M"
  },
  "surfaces": [
    "handoff resume"
  ],
  "severity": "high",
  "repair_present": true,
  "trigger": {
    "description": "A strict machine-bound handoff capsule is resumed on a machine where the local handoff machine salt file is absent.",
    "setup_commands": [
      "ee init --workspace .",
      "ee handoff create --workspace . --out capsule.json --bind-to-machine --json",
      "mv ~/.local/share/ee/keys/handoff_machine_salt ~/.local/share/ee/keys/handoff_machine_salt.backup"
    ],
    "invocation": "ee handoff resume capsule.json --workspace . --json"
  },
  "expected_emission": {
    "code": "strict_mode_no_salt_file",
    "severity": "high",
    "message_contains": [
      "key material is missing",
      "capsule"
    ],
    "repair_contains": "Resume on the machine/workspace",
    "repair_string": "Resume on the machine/workspace that created the capsule, or recreate the capsule."
  }
}
