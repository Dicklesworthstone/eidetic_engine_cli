            "memoriesDemoted": 1,
            "memoriesTombstoned": 1,
            "halfLivesApplied": true,
            "thresholdDemote": 0.05,
            "thresholdForget": 0.01,
            "dryRun": false
          },
          "summary": {
            "scannedCount": 3,
            "changedCount": 2,
            "appliedCount": 2,
            "skippedCount": 1,
            "demotedCount": 1,
            "tombstonedCount": 1
          }
        }
      }
    ]
  }
