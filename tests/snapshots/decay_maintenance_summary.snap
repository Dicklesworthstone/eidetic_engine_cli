    "summary": {
      "total": 1,
      "succeeded": 1,
      "skipped": 0,
      "failed": 0
    },
    "results": [
      {
        "jobType": "decay_sweep",
        "outcome": "success",
        "dryRun": false,
        "details": {
          "schema": "ee.steward.score_decay.v1",
          "command": "score_decay",
          "decay": {
            "schema": "decay_v1",
