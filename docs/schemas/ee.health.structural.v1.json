{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/ee.health.structural.v1.json",
  "title": "ee.health.structural.v1",
  "description": "Structural health report using graph-derived coherence signals.",
  "type": "object",
  "required": ["schema", "snapshotVersion", "kTruss", "contradictionClusters", "summary", "degraded"],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "const": "ee.health.structural.v1"},
    "snapshotVersion": {"type": ["integer", "string"]},
    "kTruss": {"$ref": "#/$defs/jsonObject"},
    "contradictionClusters": {"type": "array", "items": {"$ref": "#/$defs/jsonObject"}},
    "summary": {"$ref": "#/$defs/jsonObject"},
    "degraded": {"type": "array", "items": {"$ref": "#/$defs/jsonObject"}}
  },
  "field_presets": {
    "minimal": ["schema", "snapshotVersion"],
    "summary": ["schema", "snapshotVersion", "summary", "degraded"],
    "standard": ["schema", "snapshotVersion", "kTruss", "contradictionClusters", "summary", "degraded"],
    "full": ["*"]
  },
  "examples": [
    {
      "schema": "ee.health.structural.v1",
      "snapshotVersion": 42,
      "kTruss": {
        "maxK": 5,
        "supportSubgraphMemoryCount": 18,
        "topMembers": [
          {
            "memoryId": "mem_release_policy",
            "k": 5,
            "triangleSupport": 9
          },
          {
            "memoryId": "mem_remote_required",
            "k": 4,
            "triangleSupport": 6
          }
        ]
      },
      "contradictionClusters": [
        {
          "clusterId": "contradictions.release-readiness",
          "memoryCount": 4,
          "contradictionDensity": 0.33,
          "exampleMemoryIds": [
            "mem_old_release_rule",
            "mem_new_release_rule"
          ]
        }
      ],
      "summary": {
        "status": "degraded_recoverable",
        "kTrussMaxK": 5,
        "contradictionClusterCount": 1,
        "recommendedCommand": "ee curate candidates --workspace . --json"
      },
      "degraded": []
    }
  ],
  "$defs": {
    "jsonObject": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
    "jsonValue": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"type": "number"},
        {"type": "string"},
        {"type": "array", "items": {"$ref": "#/$defs/jsonValue"}},
        {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}}
      ]
    }
  }
}
