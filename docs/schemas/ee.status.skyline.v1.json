{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/ee.status.skyline.v1.json",
  "title": "ee.status.skyline.v1",
  "description": "Knowledge skyline block for ee status graph-accretion output.",
  "type": "object",
  "required": ["schema", "snapshotVersion", "skyline", "summary", "degraded"],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "const": "ee.status.skyline.v1"},
    "snapshotVersion": {"type": ["integer", "string"]},
    "skyline": {"type": "array", "items": {"$ref": "#/$defs/jsonObject"}},
    "summary": {"$ref": "#/$defs/jsonObject"},
    "degraded": {"type": "array", "items": {"$ref": "#/$defs/jsonObject"}}
  },
  "field_presets": {
    "minimal": ["schema", "snapshotVersion"],
    "summary": ["schema", "snapshotVersion", "summary", "degraded"],
    "standard": ["schema", "snapshotVersion", "skyline", "summary", "degraded"],
    "full": ["*"]
  },
  "examples": [
    {
      "schema": "ee.status.skyline.v1",
      "snapshotVersion": 42,
      "skyline": [
        {
          "communityId": "release-readiness",
          "onionLayer": 2,
          "memoryCount": 12,
          "meanTrust": 0.91,
          "meanAgeDays": 3.5,
          "structuralHealth": "strong"
        },
        {
          "communityId": "rch-topology",
          "onionLayer": 4,
          "memoryCount": 7,
          "meanTrust": 0.84,
          "meanAgeDays": 1.2,
          "structuralHealth": "watch"
        }
      ],
      "summary": {
        "communityCount": 2,
        "loadBearingMemoryCount": 3,
        "staleCommunityCount": 0,
        "highestRiskCommunityId": "rch-topology"
      },
      "degraded": [
        {
          "code": "graph_skyline_degenerate_communities",
          "severity": "info",
          "message": "Knowledge skyline communities are degenerate because fewer than three Louvain communities were found."
        }
      ]
    }
  ],
  "$defs": {
    "jsonObject": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
    "jsonValue": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"type": "number"},
        {"type": "string"},
        {"type": "array", "items": {"$ref": "#/$defs/jsonValue"}},
        {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}}
      ]
    }
  }
}
