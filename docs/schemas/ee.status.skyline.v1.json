{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/ee.status.skyline.v1.json",
  "title": "ee.status.skyline.v1",
  "description": "Knowledge skyline block for ee status graph-accretion output.",
  "type": "object",
  "required": ["schema", "snapshotVersion", "skyline", "summary", "degraded"],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "const": "ee.status.skyline.v1"},
    "snapshotVersion": {"type": ["integer", "string"]},
    "skyline": {"type": "array", "items": {"$ref": "#/$defs/jsonObject"}},
    "summary": {"$ref": "#/$defs/jsonObject"},
    "degraded": {"type": "array", "items": {"$ref": "#/$defs/jsonObject"}}
  },
  "field_presets": {
    "minimal": ["schema", "snapshotVersion"],
    "summary": ["schema", "snapshotVersion", "summary", "degraded"],
    "standard": ["schema", "snapshotVersion", "skyline", "summary", "degraded"],
    "full": ["*"]
  },
  "$defs": {
    "jsonObject": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
    "jsonValue": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"type": "number"},
        {"type": "string"},
        {"type": "array", "items": {"$ref": "#/$defs/jsonValue"}},
        {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}}
      ]
    }
  }
}
