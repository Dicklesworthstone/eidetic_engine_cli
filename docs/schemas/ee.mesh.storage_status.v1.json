      "minimum": 0
    },
    "cursorCount": {
      "type": "integer",
      "minimum": 0
    },
    "importedEventCount": {
      "type": "integer",
      "minimum": 0
    },
    "policyFailureEventCount": {
      "type": "integer",
      "minimum": 0
    },
    "mappedMemoryCount": {
      "type": "integer",
      "minimum": 0
    },
