{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/ee.response.v1.json",
  "title": "ee.response.v1",
  "description": "Canonical success or degraded-success response envelope for ee commands. Command-specific schemas constrain the data payload.",
  "type": "object",
  "required": ["schema", "success", "data"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "ee.response.v1"
    },
    "success": {
      "type": "boolean"
    },
    "fields": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "description": "Command-specific payload. See the per-command schema files in docs/schemas/."
    },
    "degraded": {
      "type": "array",
      "items": {"$ref": "#/$defs/degradation"}
    }
  },
  "field_presets": {
    "minimal": ["schema", "success", "data"],
    "summary": ["schema", "success", "fields", "data"],
    "standard": ["schema", "success", "fields", "data", "degraded"],
    "full": ["*"]
  },
  "$defs": {
    "degradation": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {"type": "string"},
        "severity": {"type": "string", "enum": ["low", "medium", "high"]},
        "message": {"type": "string"},
        "repair": {"type": "string"}
      }
    }
  }
}
