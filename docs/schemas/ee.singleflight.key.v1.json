{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/ee.singleflight.key.v1.json",
  "title": "ee.singleflight.key.v1",
  "description": "Redaction-safe canonical key for coalescing duplicate in-process read-heavy ee commands.",
  "type": "object",
  "required": [
    "schema",
    "canonicalVersion",
    "keyHash",
    "surface",
    "workspaceHash",
    "workspaceGeneration",
    "indexGeneration",
    "graphGeneration",
    "outputSchema",
    "queryShapeHash",
    "optionHash",
    "featureFlagHash",
    "profile",
    "maxTokens",
    "asOf",
    "sourceMode",
    "redactionLevel",
    "explain",
    "verbose"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "type": "string", "const": "ee.singleflight.key.v1" },
    "canonicalVersion": { "type": "integer", "const": 1 },
    "keyHash": { "$ref": "#/$defs/hash" },
    "surface": {
      "type": "string",
      "enum": ["context", "search", "graph_snapshot", "graph_feature_enrichment"]
    },
    "workspaceHash": { "$ref": "#/$defs/hash" },
    "workspaceGeneration": { "type": "integer", "minimum": 0 },
    "indexGeneration": { "type": ["integer", "null"], "minimum": 0 },
    "graphGeneration": { "type": ["integer", "null"], "minimum": 0 },
    "outputSchema": { "type": "string", "minLength": 1 },
    "queryShapeHash": { "oneOf": [{ "$ref": "#/$defs/hash" }, { "type": "null" }] },
    "optionHash": { "$ref": "#/$defs/hash" },
    "featureFlagHash": { "$ref": "#/$defs/hash" },
    "profile": { "type": ["string", "null"] },
    "maxTokens": { "type": ["integer", "null"], "minimum": 1 },
    "asOf": { "type": ["string", "null"] },
    "sourceMode": { "type": ["string", "null"] },
    "redactionLevel": { "type": ["string", "null"] },
    "explain": { "type": "boolean" },
    "verbose": { "type": "boolean" }
  },
  "field_presets": {
    "minimal": ["schema", "keyHash", "surface"],
    "summary": ["schema", "keyHash", "surface", "workspaceGeneration", "outputSchema"],
    "standard": [
      "schema",
      "canonicalVersion",
      "keyHash",
      "surface",
      "workspaceHash",
      "workspaceGeneration",
      "indexGeneration",
      "graphGeneration",
      "outputSchema",
      "queryShapeHash",
      "optionHash",
      "featureFlagHash",
      "profile",
      "maxTokens",
      "asOf",
      "sourceMode",
      "redactionLevel",
      "explain",
      "verbose"
    ],
    "full": ["*"]
  },
  "examples": [
    {
      "schema": "ee.singleflight.key.v1",
      "canonicalVersion": 1,
      "keyHash": "sha256:example-key",
      "surface": "context",
      "workspaceHash": "sha256:example-workspace",
      "workspaceGeneration": 42,
      "indexGeneration": 17,
      "graphGeneration": 9,
      "outputSchema": "ee.context.v1",
      "queryShapeHash": "sha256:example-query-shape",
      "optionHash": "sha256:example-options",
      "featureFlagHash": "sha256:example-feature-flags",
      "profile": "balanced",
      "maxTokens": 4000,
      "asOf": null,
      "sourceMode": "hybrid",
      "redactionLevel": "standard",
      "explain": true,
      "verbose": false
    }
  ],
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^(sha256|blake3):[A-Za-z0-9._:-]+$"
    }
  }
}
