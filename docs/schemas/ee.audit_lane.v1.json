{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/ee.audit_lane.v1.json",
  "title": "ee.audit_lane.v1",
  "description": "Structured audit-lane telemetry event emitted by the Swarm-X audit queue.",
  "type": "object",
  "required": [
    "schema",
    "phase",
    "workspaceId",
    "requestId",
    "auditSeq",
    "batchSize",
    "elapsedMs",
    "degradedCodes"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "ee.audit_lane.v1"
    },
    "phase": {
      "type": "string",
      "enum": [
        "enqueue",
        "drain",
        "batch_commit",
        "shutdown",
        "backpressure"
      ]
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "requestId": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 256
    },
    "auditSeq": {
      "description": "Per-workspace audit-lane sequence number assigned before enqueue. Zero means no row was accepted for this event.",
      "type": "integer",
      "minimum": 0
    },
    "batchSize": {
      "description": "Number of events drained or committed in this phase. Enqueue/backpressure events use 0 or 1.",
      "type": "integer",
      "minimum": 0
    },
    "elapsedMs": {
      "type": "integer",
      "minimum": 0
    },
    "degradedCodes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "audit_backpressure",
          "audit_lane_shutdown_drain_timeout"
        ]
      }
    }
  }
}
