{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/ee.agent_operating_contract.v1.json",
  "title": "ee.agent_operating_contract.v1",
  "description": "Read-only operating rules extracted from repository-local agent instructions and README requirements.",
  "type": "object",
  "required": ["schema", "rules", "reporting_obligations", "degraded"],
  "properties": {
    "schema": {
      "const": "ee.agent_operating_contract.v1"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "category",
          "source_file",
          "source_heading",
          "line_start",
          "line_end",
          "excerpt_hash",
          "instruction"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^agent\\.[a-z0-9_]+$"
          },
          "severity": {
            "enum": ["info", "low", "warning", "medium", "high", "critical"]
          },
          "category": {
            "enum": [
              "hard_denial",
              "required_before_edit",
              "required_before_verify",
              "coordination_required",
              "environment_fact",
              "reporting_required",
              "advisory"
            ]
          },
          "source_file": {
            "enum": ["AGENTS.md", "README.md"]
          },
          "source_heading": {
            "type": "string",
            "minLength": 1
          },
          "line_start": {
            "type": "integer",
            "minimum": 1
          },
          "line_end": {
            "type": "integer",
            "minimum": 1
          },
          "excerpt_hash": {
            "type": "string",
            "pattern": "^blake3:[0-9a-f]{16}$"
          },
          "instruction": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    },
    "reporting_obligations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "obligation_type",
          "trigger",
          "instruction",
          "evidence_kinds",
          "evidence_refs",
          "gap_code"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^agent\\.report\\.[a-z0-9_]+$"
          },
          "severity": {
            "enum": ["info", "low", "warning", "medium", "high", "critical"]
          },
          "obligation_type": {
            "enum": ["must_report", "advisory"]
          },
          "trigger": {
            "type": "string",
            "minLength": 1
          },
          "instruction": {
            "type": "string",
            "minLength": 1
          },
          "evidence_kinds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "gap_code": {
            "type": ["string", "null"],
            "enum": [
              "missing_rch_proof",
              "dirty_worktree_caveat_required",
              "destructive_command_audit_required",
              "memory_citation_required",
              null
            ]
          }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    },
    "degraded": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "repair"],
        "properties": {
          "code": {
            "enum": ["agent_contract_source_unavailable"]
          },
          "severity": {
            "enum": ["info", "low", "warning", "medium", "high", "critical"]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "repair": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "field_presets": {
    "minimal": ["schema"],
    "summary": ["schema", "rules", "reporting_obligations", "degraded"],
    "standard": ["schema", "rules", "reporting_obligations", "degraded"],
    "full": ["*"]
  }
}
