{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/ee.status.v1.json",
  "title": "ee.status.v1",
  "description": "ee status response envelope.",
  "type": "object",
  "required": ["schema", "success", "data"],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "const": "ee.response.v1"},
    "success": {"type": "boolean"},
    "fields": {"type": "string"},
    "data": {
      "type": "object",
      "required": [
        "command",
        "version",
        "workspace",
        "posture",
        "capabilities",
        "runtime",
        "read_pool",
        "wal",
        "qos",
        "memoryHealth",
        "curationHealth",
        "feedbackHealth",
        "singleFlight",
        "graphCompute",
        "graphSnapshotArtifact",
        "derivedAssets",
        "agentInventory",
        "degraded"
      ],
      "additionalProperties": false,
      "properties": {
        "command": {"type": "string", "const": "status"},
        "version": {"type": "string"},
        "workspace": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
        "posture": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
        "capabilities": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
        "runtime": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
        "read_pool": {"$ref": "#/$defs/readPoolStatus"},
        "wal": {"$ref": "#/$defs/walStatus"},
        "qos": {"$ref": "#/$defs/qosStatus"},
        "memoryHealth": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
        "curationHealth": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
        "feedbackHealth": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
        "singleFlight": {"$ref": "#/$defs/singleFlightPosture"},
        "graphCompute": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
        "graphSnapshotArtifact": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
        "derivedAssets": {"type": "array", "items": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}}},
        "agentInventory": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}},
        "degraded": {"type": "array", "items": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}}}
      }
    }
  },
  "field_presets": {
    "minimal": ["command", "version", "workspace"],
    "summary": ["command", "version", "workspace", "posture", "singleFlight", "qos", "capabilities"],
    "standard": ["command", "version", "workspace", "posture", "capabilities", "runtime", "read_pool", "wal", "qos", "memoryHealth", "curationHealth", "feedbackHealth", "singleFlight", "graphCompute", "graphSnapshotArtifact", "derivedAssets", "agentInventory", "degraded"],
    "full": ["*"]
  },
  "$defs": {
    "readPoolStatus": {
      "type": "object",
      "required": ["active", "idle", "active_pins", "expired_pins", "max_seen", "drops", "release_failures", "ad_hoc_bypass_count", "acquire_wait", "checkpoint_blocked_by"],
      "additionalProperties": false,
      "properties": {
        "active": {"type": "integer", "minimum": 0},
        "idle": {"type": "integer", "minimum": 0},
        "active_pins": {"type": "integer", "minimum": 0},
        "expired_pins": {"type": "integer", "minimum": 0},
        "max_seen": {"type": "integer", "minimum": 0},
        "drops": {"type": "integer", "minimum": 0},
        "release_failures": {"type": "integer", "minimum": 0},
        "ad_hoc_bypass_count": {"type": "integer", "minimum": 0},
        "acquire_wait": {
          "type": "object",
          "required": ["samples", "p50_ns", "p99_ns"],
          "additionalProperties": false,
          "properties": {
            "samples": {"type": "integer", "minimum": 0},
            "p50_ns": {"type": "integer", "minimum": 0},
            "p99_ns": {"type": "integer", "minimum": 0}
          }
        },
        "checkpoint_blocked_by": {
          "description": "Forward-looking checkpoint blocker attribution: the oldest active SnapshotPin in this process's read pool. If a `wal_checkpoint` were attempted now and returned BUSY, this entry is the most likely blocker. Null when no pins are active. Process-local: a reader pinning the WAL from a different process is not visible here.",
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": ["pin_id", "slot_id", "workflow_id", "request_id", "workspace_id", "pin_age_ms", "max_pin_duration_ms", "poisoned", "release_state"],
              "additionalProperties": false,
              "properties": {
                "pin_id": {"type": "integer", "minimum": 0},
                "slot_id": {"type": ["integer", "null"], "minimum": 0},
                "workflow_id": {"type": ["string", "null"]},
                "request_id": {"type": ["string", "null"]},
                "workspace_id": {"type": ["string", "null"]},
                "pin_age_ms": {"type": "integer", "minimum": 0},
                "max_pin_duration_ms": {"type": "integer", "minimum": 0},
                "poisoned": {"type": "boolean"},
                "release_state": {"type": "string", "enum": ["active", "expired", "poisoned"]}
              }
            }
          ]
        }
      }
    },
    "walStatus": {
      "type": "object",
      "required": ["bytes", "frames", "page_size", "checkpoint_threshold_bytes"],
      "additionalProperties": false,
      "properties": {
        "bytes": {"type": "integer", "minimum": 0},
        "frames": {"type": "integer", "minimum": 0},
        "page_size": {"type": "integer", "minimum": 0},
        "checkpoint_threshold_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "qosStatus": {
      "type": "object",
      "required": [
        "schema",
        "workspaceHash",
        "foregroundActiveCount",
        "backgroundActiveCount",
        "verificationActiveCount",
        "maintenanceActiveCount",
        "staleIgnoredCount",
        "foregroundPressure",
        "backgroundWorkActive",
        "registryHealthy",
        "degraded"
      ],
      "additionalProperties": false,
      "properties": {
        "schema": {"type": "string", "const": "ee.qos.active_lane_summary.v1"},
        "workspaceHash": {"type": "string", "minLength": 8},
        "foregroundActiveCount": {"type": "integer", "minimum": 0},
        "backgroundActiveCount": {"type": "integer", "minimum": 0},
        "verificationActiveCount": {"type": "integer", "minimum": 0},
        "maintenanceActiveCount": {"type": "integer", "minimum": 0},
        "staleIgnoredCount": {"type": "integer", "minimum": 0},
        "foregroundPressure": {"type": "boolean"},
        "backgroundWorkActive": {"type": "boolean"},
        "registryHealthy": {"type": "boolean"},
        "activeRecords": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}}
        },
        "degraded": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}}
        }
      }
    },
    "singleFlightStatus": {
      "type": "string",
      "enum": ["idle", "active", "observed_failures", "state_poisoned", "unconfigured"]
    },
    "singleFlightPosture": {
      "type": "object",
      "required": [
        "schema",
        "status",
        "configuredSurfaceCount",
        "activeLeaderCount",
        "leaderStartCount",
        "followerWaitCount",
        "followerTimeoutCount",
        "leaderFailureCount",
        "reusedResultCount",
        "surfaces"
      ],
      "additionalProperties": false,
      "properties": {
        "schema": {"type": "string", "const": "ee.singleflight.posture.v1"},
        "status": {"$ref": "#/$defs/singleFlightStatus"},
        "configuredSurfaceCount": {"type": "integer", "minimum": 0},
        "activeLeaderCount": {"type": "integer", "minimum": 0},
        "leaderStartCount": {"type": "integer", "minimum": 0},
        "followerWaitCount": {"type": "integer", "minimum": 0},
        "followerTimeoutCount": {"type": "integer", "minimum": 0},
        "leaderFailureCount": {"type": "integer", "minimum": 0},
        "reusedResultCount": {"type": "integer", "minimum": 0},
        "surfaces": {
          "type": "array",
          "items": {"$ref": "#/$defs/singleFlightSurfacePosture"}
        }
      }
    },
    "singleFlightSurfacePosture": {
      "type": "object",
      "required": [
        "surface",
        "status",
        "configured",
        "activeLeaderCount",
        "leaderStartCount",
        "completedLeaderCount",
        "followerJoinCount",
        "followerTimeoutCount",
        "leaderFailureCount",
        "reusedResultCount",
        "statePoisonedCount",
        "followerTimeoutMs",
        "lastKey",
        "suggestedAction"
      ],
      "additionalProperties": false,
      "properties": {
        "surface": {
          "type": "string",
          "enum": ["context", "search", "graph_snapshot", "graph_feature_enrichment"]
        },
        "status": {"$ref": "#/$defs/singleFlightStatus"},
        "configured": {"type": "boolean"},
        "activeLeaderCount": {"type": "integer", "minimum": 0},
        "leaderStartCount": {"type": "integer", "minimum": 0},
        "completedLeaderCount": {"type": "integer", "minimum": 0},
        "followerJoinCount": {"type": "integer", "minimum": 0},
        "followerTimeoutCount": {"type": "integer", "minimum": 0},
        "leaderFailureCount": {"type": "integer", "minimum": 0},
        "reusedResultCount": {"type": "integer", "minimum": 0},
        "statePoisonedCount": {"type": "integer", "minimum": 0},
        "followerTimeoutMs": {"type": "integer", "minimum": 0},
        "lastKey": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/singleFlightLastKey"}]
        },
        "suggestedAction": {"type": "string", "minLength": 1}
      }
    },
    "singleFlightLastKey": {
      "type": "object",
      "required": ["keyHash", "workspaceGeneration", "indexGeneration", "graphGeneration"],
      "additionalProperties": false,
      "properties": {
        "keyHash": {"type": "string", "minLength": 8},
        "workspaceGeneration": {"type": "integer", "minimum": 0},
        "indexGeneration": {"type": ["integer", "null"], "minimum": 0},
        "graphGeneration": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "jsonValue": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"type": "number"},
        {"type": "string"},
        {"type": "array", "items": {"$ref": "#/$defs/jsonValue"}},
        {"type": "object", "additionalProperties": {"$ref": "#/$defs/jsonValue"}}
      ]
    }
  }
}
