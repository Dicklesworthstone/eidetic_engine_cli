{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/ee.graph.witness_prune_report.v1.json",
  "title": "ee.graph.witness_prune_report.v1",
  "description": "Dry-run or durable graph algorithm witness prune report with active-snapshot safety.",
  "type": "object",
  "required": [
    "schema",
    "command",
    "workspace",
    "workspaceId",
    "databasePath",
    "dryRun",
    "durableMutation",
    "deletedCount",
    "report",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "const": "ee.graph.witness_prune_report.v1"},
    "command": {"type": "string", "const": "maintenance graph-witnesses-prune"},
    "workspace": {"type": "string", "minLength": 1},
    "workspaceId": {"type": "string", "minLength": 1},
    "databasePath": {"type": "string", "minLength": 1},
    "dryRun": {"type": "boolean"},
    "durableMutation": {"type": "boolean"},
    "deletedCount": {"type": "integer", "minimum": 0},
    "report": {"$ref": "#/$defs/witnessPruneReport"},
    "summary": {"$ref": "#/$defs/witnessPruneSummaryWithDelete"},
    "degraded": {
      "type": "array",
      "items": {"$ref": "#/$defs/degradation"}
    }
  },
  "field_presets": {
    "minimal": ["schema", "workspaceId", "dryRun", "deletedCount", "summary"],
    "summary": [
      "schema",
      "command",
      "workspaceId",
      "dryRun",
      "durableMutation",
      "deletedCount",
      "summary",
      "degraded"
    ],
    "standard": ["*"],
    "full": ["*"]
  },
  "examples": [
    {
      "schema": "ee.graph.witness_prune_report.v1",
      "command": "maintenance graph-witnesses-prune",
      "workspace": "/repo",
      "workspaceId": "wsp_release_readiness",
      "databasePath": "/repo/.ee/ee.db",
      "dryRun": true,
      "durableMutation": false,
      "deletedCount": 0,
      "report": {
        "schema": "ee.graph.witness_prune_report.v1",
        "now": "2026-05-16T20:00:00Z",
        "policy": {
          "defaultTtlDays": 30,
          "perAlgorithmTtlDays": {
            "cache_results": 90
          }
        },
        "classifications": [
          {
            "workspaceId": "wsp_release_readiness",
            "snapshotId": "gsnap_archived_old",
            "algorithm": "ppr",
            "recordedAt": "2026-04-01T20:00:00Z",
            "action": {
              "kind": "prune",
              "ageDays": 45,
              "ttlDays": 30
            }
          },
          {
            "workspaceId": "wsp_release_readiness",
            "snapshotId": "gsnap_active",
            "algorithm": "hits",
            "recordedAt": "2026-03-16T20:00:00Z",
            "action": {
              "kind": "keep",
              "reason": {
                "code": "active_snapshot"
              }
            }
          }
        ],
        "summary": {
          "totalCount": 2,
          "pruneCount": 1,
          "keepActiveSnapshotCount": 1,
          "keepWithinTtlCount": 0,
          "keepUnparseableRecordedAtCount": 0,
          "oldestPrunedAgeDays": 45,
          "oldestKeptAgeDays": 61
        }
      },
      "summary": {
        "totalCount": 2,
        "pruneCount": 1,
        "keepActiveSnapshotCount": 1,
        "keepWithinTtlCount": 0,
        "keepUnparseableRecordedAtCount": 0,
        "oldestPrunedAgeDays": 45,
        "oldestKeptAgeDays": 61,
        "deletedCount": 0
      }
    }
  ],
  "$defs": {
    "witnessPruneReport": {
      "type": "object",
      "required": ["schema", "now", "policy", "classifications", "summary"],
      "additionalProperties": false,
      "properties": {
        "schema": {"type": "string", "const": "ee.graph.witness_prune_report.v1"},
        "now": {"type": "string", "minLength": 1},
        "policy": {"$ref": "#/$defs/witnessRetentionPolicy"},
        "classifications": {
          "type": "array",
          "items": {"$ref": "#/$defs/witnessClassification"}
        },
        "summary": {"$ref": "#/$defs/witnessPruneSummary"}
      }
    },
    "witnessRetentionPolicy": {
      "type": "object",
      "required": ["defaultTtlDays", "perAlgorithmTtlDays"],
      "additionalProperties": false,
      "properties": {
        "defaultTtlDays": {"type": "integer", "minimum": 0},
        "perAlgorithmTtlDays": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        }
      }
    },
    "witnessClassification": {
      "type": "object",
      "required": ["workspaceId", "snapshotId", "algorithm", "recordedAt", "action"],
      "additionalProperties": false,
      "properties": {
        "workspaceId": {"type": "string", "minLength": 1},
        "snapshotId": {"type": "string", "minLength": 1},
        "algorithm": {"type": "string", "minLength": 1},
        "recordedAt": {"type": "string", "minLength": 1},
        "action": {"$ref": "#/$defs/witnessAction"}
      }
    },
    "witnessAction": {
      "oneOf": [
        {"$ref": "#/$defs/pruneAction"},
        {"$ref": "#/$defs/keepAction"}
      ]
    },
    "pruneAction": {
      "type": "object",
      "required": ["kind", "ageDays", "ttlDays"],
      "additionalProperties": false,
      "properties": {
        "kind": {"type": "string", "const": "prune"},
        "ageDays": {"type": "integer", "minimum": 0},
        "ttlDays": {"type": "integer", "minimum": 0}
      }
    },
    "keepAction": {
      "type": "object",
      "required": ["kind", "reason"],
      "additionalProperties": false,
      "properties": {
        "kind": {"type": "string", "const": "keep"},
        "reason": {"$ref": "#/$defs/witnessKeepReason"}
      }
    },
    "witnessKeepReason": {
      "oneOf": [
        {"$ref": "#/$defs/activeSnapshotReason"},
        {"$ref": "#/$defs/withinTtlReason"},
        {"$ref": "#/$defs/unparseableRecordedAtReason"}
      ]
    },
    "activeSnapshotReason": {
      "type": "object",
      "required": ["code"],
      "additionalProperties": false,
      "properties": {
        "code": {"type": "string", "const": "active_snapshot"}
      }
    },
    "withinTtlReason": {
      "type": "object",
      "required": ["code", "ageDays", "ttlDays"],
      "additionalProperties": false,
      "properties": {
        "code": {"type": "string", "const": "within_ttl"},
        "ageDays": {"type": "integer", "minimum": 0},
        "ttlDays": {"type": "integer", "minimum": 0}
      }
    },
    "unparseableRecordedAtReason": {
      "type": "object",
      "required": ["code"],
      "additionalProperties": false,
      "properties": {
        "code": {"type": "string", "const": "unparseable_recorded_at"}
      }
    },
    "witnessPruneSummary": {
      "type": "object",
      "required": [
        "totalCount",
        "pruneCount",
        "keepActiveSnapshotCount",
        "keepWithinTtlCount",
        "keepUnparseableRecordedAtCount",
        "oldestPrunedAgeDays",
        "oldestKeptAgeDays"
      ],
      "additionalProperties": false,
      "properties": {
        "totalCount": {"type": "integer", "minimum": 0},
        "pruneCount": {"type": "integer", "minimum": 0},
        "keepActiveSnapshotCount": {"type": "integer", "minimum": 0},
        "keepWithinTtlCount": {"type": "integer", "minimum": 0},
        "keepUnparseableRecordedAtCount": {"type": "integer", "minimum": 0},
        "oldestPrunedAgeDays": {"type": ["integer", "null"], "minimum": 0},
        "oldestKeptAgeDays": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "witnessPruneSummaryWithDelete": {
      "type": "object",
      "required": [
        "totalCount",
        "pruneCount",
        "keepActiveSnapshotCount",
        "keepWithinTtlCount",
        "keepUnparseableRecordedAtCount",
        "oldestPrunedAgeDays",
        "oldestKeptAgeDays",
        "deletedCount"
      ],
      "additionalProperties": false,
      "properties": {
        "totalCount": {"type": "integer", "minimum": 0},
        "pruneCount": {"type": "integer", "minimum": 0},
        "keepActiveSnapshotCount": {"type": "integer", "minimum": 0},
        "keepWithinTtlCount": {"type": "integer", "minimum": 0},
        "keepUnparseableRecordedAtCount": {"type": "integer", "minimum": 0},
        "oldestPrunedAgeDays": {"type": ["integer", "null"], "minimum": 0},
        "oldestKeptAgeDays": {"type": ["integer", "null"], "minimum": 0},
        "deletedCount": {"type": "integer", "minimum": 0}
      }
    },
    "degradation": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "additionalProperties": true,
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "severity": {"type": "string", "enum": ["info", "low", "warning", "medium", "high", "critical"]},
        "message": {"type": "string", "minLength": 1},
        "repair": {"type": "string"}
      }
    }
  }
}
