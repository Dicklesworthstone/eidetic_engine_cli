{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/ee.mesh.policy_failure_surface.v1.json",
  "title": "ee.mesh.policy_failure_surface.v1",
  "description": "Structured, redaction-safe authorization failure surface for optional mesh memory policy decisions.",
  "type": "object",
  "required": [
    "schema",
    "code",
    "action",
    "reason",
    "policyRef",
    "materialLane",
    "redaction",
    "trustLane"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "ee.mesh.policy_failure_surface.v1"
    },
    "code": {
      "type": "string",
      "enum": [
        "mesh_peer_policy_denied",
        "mesh_peer_policy_quarantined",
        "mesh_peer_policy_rejected",
        "mesh_outbound_policy_denied",
        "mesh_outbound_policy_quarantined",
        "mesh_outbound_policy_rejected"
      ]
    },
    "action": {
      "type": "string",
      "enum": ["deny", "quarantine", "reject"]
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9_:-]+$"
    },
    "policyRef": {
      "description": "Either the literal missing-policy sentinel or a redaction-safe policy alias. Raw path-like policy IDs must be hashed before they reach this field.",
      "type": "string",
      "pattern": "^(missing|[A-Za-z0-9._:-]{6,160})$"
    },
    "materialLane": {
      "type": "string",
      "enum": [
        "metadata",
        "body",
        "embedding",
        "graphLink",
        "revisionNotice",
        "curationSignal"
      ]
    },
    "redaction": {
      "type": "string",
      "enum": ["share", "redact", "deny"]
    },
    "trustLane": {
      "type": ["string", "null"],
      "enum": [
        "localHuman",
        "peerHumanViaPeer",
        "peerAgent",
        "peerDerived",
        "untrusted",
        null
      ]
    }
  }
}
