{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eidetic-engine/schemas/swarm/ee.support_bundle.swarm_brief_summary.v1.json",
  "title": "ee.support_bundle.swarm_brief_summary.v1",
  "description": "Redacted support-bundle summary derived from ee.swarm.brief.v1.",
  "type": "object",
  "required": [
    "schema",
    "sourceSchema",
    "source",
    "status",
    "redactionStatus",
    "reportHash",
    "workspaceHash",
    "limits",
    "counts",
    "bv",
    "sourceStatusCounts",
    "sourceStatuses",
    "resourcePressurePosture",
    "singleFlight",
    "degradedCodes",
    "fileSurfaceRiskSummary",
    "topRecommendations",
    "provenance",
    "redaction"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "ee.support_bundle.swarm_brief_summary.v1"},
    "sourceSchema": {"const": "ee.swarm.brief.v1"},
    "source": {"const": "read_only_swarm_brief_report"},
    "status": {"type": "string"},
    "redactionStatus": {"const": "counts_hashes_codes_ids_only_no_mail_body_no_raw_queries_no_file_listings"},
    "reportHash": {"type": "string", "pattern": "^blake3:"},
    "workspaceHash": {"type": "string", "pattern": "^blake3:"},
    "limits": {"type": "object"},
    "counts": {"type": "object"},
    "bv": {"type": "object"},
    "sourceStatusCounts": {"type": "object"},
    "sourceStatuses": {
      "type": "array",
      "items": {"type": "object"}
    },
    "resourcePressurePosture": {"type": "string"},
    "singleFlight": {"$ref": "#/definitions/singleFlightPosture"},
    "degradedCodes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "fileSurfaceRiskSummary": {"$ref": "#/definitions/fileSurfaceRiskSummary"},
    "topRecommendations": {
      "type": "array",
      "items": {"type": "object"}
    },
    "provenance": {"type": "object"},
    "redaction": {"$ref": "#/definitions/redaction"}
  },
  "definitions": {
    "stringArray": {
      "type": "array",
      "items": {"type": "string"}
    },
    "fileSurfaceRiskSummary": {
      "type": "object",
      "required": ["countsBySeverity", "countsByReservationHolder", "countsByGitStatus", "topRisks"],
      "additionalProperties": false,
      "properties": {
        "countsBySeverity": {"type": "object"},
        "countsByReservationHolder": {"type": "object"},
        "countsByGitStatus": {"type": "object"},
        "topRisks": {
          "type": "array",
          "items": {"$ref": "#/definitions/topRisk"}
        }
      }
    },
    "singleFlightPosture": {
      "type": "object",
      "required": [
        "schema",
        "status",
        "configuredSurfaceCount",
        "activeLeaderCount",
        "leaderStartCount",
        "followerWaitCount",
        "followerTimeoutCount",
        "leaderFailureCount",
        "reusedResultCount",
        "surfaces"
      ],
      "additionalProperties": false,
      "properties": {
        "schema": {"const": "ee.singleflight.posture.v1"},
        "status": {"type": "string"},
        "configuredSurfaceCount": {"type": "integer", "minimum": 0},
        "activeLeaderCount": {"type": "integer", "minimum": 0},
        "leaderStartCount": {"type": "integer", "minimum": 0},
        "followerWaitCount": {"type": "integer", "minimum": 0},
        "followerTimeoutCount": {"type": "integer", "minimum": 0},
        "leaderFailureCount": {"type": "integer", "minimum": 0},
        "reusedResultCount": {"type": "integer", "minimum": 0},
        "surfaces": {
          "type": "array",
          "items": {"$ref": "#/definitions/singleFlightSurfacePosture"}
        }
      }
    },
    "singleFlightSurfacePosture": {
      "type": "object",
      "required": [
        "surface",
        "status",
        "configured",
        "activeLeaderCount",
        "leaderStartCount",
        "completedLeaderCount",
        "followerJoinCount",
        "followerTimeoutCount",
        "leaderFailureCount",
        "reusedResultCount",
        "statePoisonedCount",
        "followerTimeoutMs",
        "lastKey",
        "suggestedAction"
      ],
      "additionalProperties": false,
      "properties": {
        "surface": {"type": "string"},
        "status": {"type": "string"},
        "configured": {"type": "boolean"},
        "activeLeaderCount": {"type": "integer", "minimum": 0},
        "leaderStartCount": {"type": "integer", "minimum": 0},
        "completedLeaderCount": {"type": "integer", "minimum": 0},
        "followerJoinCount": {"type": "integer", "minimum": 0},
        "followerTimeoutCount": {"type": "integer", "minimum": 0},
        "leaderFailureCount": {"type": "integer", "minimum": 0},
        "reusedResultCount": {"type": "integer", "minimum": 0},
        "statePoisonedCount": {"type": "integer", "minimum": 0},
        "followerTimeoutMs": {"type": "integer", "minimum": 0},
        "lastKey": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/definitions/singleFlightLastKey"}
          ]
        },
        "suggestedAction": {"type": "string"}
      }
    },
    "singleFlightLastKey": {
      "type": "object",
      "required": ["keyHash", "workspaceGeneration", "indexGeneration", "graphGeneration"],
      "additionalProperties": false,
      "properties": {
        "keyHash": {"type": "string", "pattern": "^sha256:"},
        "workspaceGeneration": {"type": "integer", "minimum": 0},
        "indexGeneration": {"oneOf": [{"type": "null"}, {"type": "integer", "minimum": 0}]},
        "graphGeneration": {"oneOf": [{"type": "null"}, {"type": "integer", "minimum": 0}]}
      }
    },
    "topRisk": {
      "type": "object",
      "required": [
        "pathHash",
        "severity",
        "score",
        "riskFactors",
        "reservationHolders",
        "relatedBeadIds",
        "suggestedCommandHashes",
        "rawPathIncluded",
        "rawCommandsIncluded"
      ],
      "additionalProperties": false,
      "properties": {
        "pathHash": {"type": "string", "pattern": "^blake3:"},
        "severity": {"type": "string", "enum": ["low", "medium", "high"]},
        "score": {"type": "integer", "minimum": 0},
        "riskFactors": {"$ref": "#/definitions/stringArray"},
        "reservationHolders": {"$ref": "#/definitions/stringArray"},
        "relatedBeadIds": {"$ref": "#/definitions/stringArray"},
        "suggestedCommandHashes": {"$ref": "#/definitions/stringArray"},
        "rawPathIncluded": {"const": false},
        "rawCommandsIncluded": {"const": false}
      }
    },
    "redaction": {
      "type": "object",
      "required": [
        "rawMailBodiesIncluded",
        "rawQueryTextIncluded",
        "rawProvenanceTextIncluded",
        "fullFileListingsIncluded",
        "recommendationEvidenceIncluded"
      ],
      "additionalProperties": false,
      "properties": {
        "rawMailBodiesIncluded": {"const": false},
        "rawQueryTextIncluded": {"const": false},
        "rawProvenanceTextIncluded": {"const": false},
        "fullFileListingsIncluded": {"const": false},
        "recommendationEvidenceIncluded": {"const": "hashes_only"}
      }
    }
  },
