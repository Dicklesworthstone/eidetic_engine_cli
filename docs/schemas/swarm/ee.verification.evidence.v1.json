      "offload": {"requiredRemote": false, "remoteRequiredEnv": null, "offloadTool": null, "worker": null, "fallbackDetected": false, "fallbackReason": null},
      "outputSummary": {"stdoutTail": null, "stderrTail": null, "redacted": false},
      "artifacts": [],
      "producer": {"schema": "ee.producer.metadata.v1", "sourceSystem": "verification", "identity": {"status": "unknown", "agentName": null, "harness": null, "model": null}, "run": {"runId": "verify-run-20260513", "sessionId": null, "workspaceFingerprint": "repo:25e38e130474e7f0292de2a3"}, "observedAt": "2026-05-13T00:00:00Z"}
    }
