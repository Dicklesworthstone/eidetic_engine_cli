{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/swarm/ee.verification.reuse_advisory.v1.json",
  "title": "ee.verification.reuse_advisory.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "beadId",
    "status",
    "requestedSourceHash",
    "requestedCommandHash",
    "requestedExecutionSubstrate",
    "featureProfileHash",
    "workspaceGeneration",
    "strictnessFlags",
    "matchedRunId",
    "matchedAgentName",
    "matchedFinishedAt",
    "reason",
    "repairActions"
  ],
  "properties": {
    "schema": { "type": "string", "const": "ee.verification.reuse_advisory.v1" },
    "beadId": { "type": ["string", "null"] },
    "status": {
      "type": "string",
      "enum": [
        "reusable_pass",
        "reusable_fail",
        "in_flight",
        "stale_source",
        "mismatched_command",
        "missing_evidence",
        "rerun_required"
      ]
    },
    "requestedSourceHash": { "type": ["string", "null"] },
    "requestedCommandHash": { "type": "string" },
    "requestedExecutionSubstrate": { "type": "string" },
    "featureProfileHash": { "type": ["string", "null"] },
    "workspaceGeneration": { "type": ["integer", "null"], "minimum": 0 },
    "strictnessFlags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "matchedRunId": { "type": ["string", "null"] },
    "matchedAgentName": { "type": ["string", "null"] },
    "matchedFinishedAt": { "type": ["string", "null"] },
    "reason": { "type": "string", "minLength": 1 },
    "repairActions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "kind", "command", "message"],
        "properties": {
          "priority": { "type": "integer", "minimum": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "command": { "type": ["string", "null"] },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "x-ee-doc": "docs/swarm/verification_reuse_advisory.md",
  "x-ee-status": {
    "shipped": true,
    "tracking_bead": "bd-1zb7k.15.2",
    "available_in_build": true
  },
  "examples": [
    {
      "schema": "ee.verification.reuse_advisory.v1",
      "beadId": "bd-example",
      "status": "reusable_pass",
      "requestedSourceHash": "blake3:source",
      "requestedCommandHash": "blake3:rch-command",
      "requestedExecutionSubstrate": "rch",
      "featureProfileHash": "blake3:profile",
      "workspaceGeneration": 42,
      "strictnessFlags": [
        "--all-targets",
        "RCH_REQUIRE_REMOTE=1"
      ],
      "matchedRunId": "vrun_rch_00000000000000000001",
      "matchedAgentName": "RubyWolf",
      "matchedFinishedAt": "2026-05-15T05:00:42Z",
      "reason": "matching verification run passed for the same source, command, and substrate",
      "repairActions": [
        {
          "priority": 1,
          "kind": "cite_existing_run",
          "command": null,
          "message": "cite the matched passing verification run instead of rerunning"
        }
      ]
    }
  ]
}
