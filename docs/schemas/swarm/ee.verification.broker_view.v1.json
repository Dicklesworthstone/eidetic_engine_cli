        "known_blocker",
        "unavailable"
      ]
    },
    "matchedRunId": { "type": ["string", "null"] },
    "commandClass": { "type": "string", "minLength": 1 },
    "commandHash": { "type": "string", "minLength": 1 },
    "normalizedArgvHash": { "type": "string", "minLength": 1 },
    "sourceTreeFingerprintClass": { "type": "string", "minLength": 1 },
    "envFingerprintClass": { "type": "string", "minLength": 1 },
    "targetProfile": { "type": ["string", "null"] },
    "executionSubstrate": { "type": "string", "minLength": 1 },
    "rch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredRemote", "workerHost", "jobId"],
      "properties": {
        "requiredRemote": { "type": "boolean" },
        "workerHost": { "type": ["string", "null"] },
        "jobId": { "type": ["string", "null"] }
      }
    },
    "exitCode": { "type": ["integer", "null"] },
    "finishedAt": { "type": ["string", "null"] },
    "compatibilityReasonCodes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "staleReasonCodes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "firstFailureSummaryRef": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "stderrExcerptHash",
        "artifactManifestHash",
        "retainedLogPathHash",
        "rawOutputIncluded"
      ],
      "properties": {
        "stderrExcerptHash": { "type": ["string", "null"] },
        "artifactManifestHash": { "type": ["string", "null"] },
        "retainedLogPathHash": { "type": ["string", "null"] },
        "rawOutputIncluded": { "type": "boolean", "const": false }
      }
    },
    "suggestedAction": { "type": "string", "minLength": 1 }
  },
  "x-ee-status": {
    "shipped": true,
    "available_in_build": true,
    "tracking_bead": "bd-6boyo.2"
  },
  "x-ee-doc": "docs/swarm/verification_broker_view.md",
  "examples": [
