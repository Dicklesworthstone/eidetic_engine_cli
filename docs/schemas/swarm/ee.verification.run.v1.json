{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic-engine/schemas/swarm/ee.verification.run.v1.json",
  "title": "ee.verification.run.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "runId",
    "beadId",
    "agentName",
    "sourceHash",
    "commandHash",
    "commandArgvHash",
    "cargoTargetDirHashOrClass",
    "executionSubstrate",
    "workerHost",
    "startedAt",
    "finishedAt",
    "exitCode",
    "stdoutHash",
    "stderrExcerptHash",
    "artifactManifestHash",
    "retainedLogPathHash",
    "provenance"
  ],
  "properties": {
    "schema": { "type": "string", "const": "ee.verification.run.v1" },
    "runId": { "type": "string", "pattern": "^vrun_[A-Za-z0-9_:-]+$" },
    "beadId": { "type": ["string", "null"] },
    "agentName": { "type": ["string", "null"] },
    "sourceHash": { "type": ["string", "null"] },
    "commandHash": { "type": "string" },
    "commandArgvHash": { "type": "string" },
    "cargoTargetDirHashOrClass": { "type": ["string", "null"] },
    "executionSubstrate": { "type": "string" },
    "workerHost": { "type": ["string", "null"] },
    "startedAt": { "type": ["string", "null"] },
    "finishedAt": { "type": ["string", "null"] },
    "exitCode": { "type": ["integer", "null"] },
    "stdoutHash": { "type": ["string", "null"] },
    "stderrExcerptHash": { "type": ["string", "null"] },
    "artifactManifestHash": { "type": ["string", "null"] },
    "retainedLogPathHash": { "type": ["string", "null"] },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "eventKind", "line"],
        "properties": {
          "source": { "type": "string" },
          "eventKind": { "type": "string" },
          "line": { "type": ["integer", "null"], "minimum": 1 }
        }
      }
    }
  },
  "x-ee-doc": "docs/swarm/verification_run.md",
  "x-ee-status": {
    "shipped": true,
    "tracking_bead": "bd-1zb7k.15.1",
    "available_in_build": true
  },
  "examples": [
    {
      "schema": "ee.verification.run.v1",
      "runId": "vrun_rch_00000000000000000001",
      "beadId": "bd-example",
      "agentName": "RubyWolf",
      "sourceHash": "blake3:source",
      "commandHash": "blake3:rch-command",
      "commandArgvHash": "blake3:rch-command-argv",
      "cargoTargetDirHashOrClass": "class:external_cargo_target",
      "executionSubstrate": "rch",
      "workerHost": "css",
      "startedAt": "2026-05-15T05:00:00Z",
      "finishedAt": "2026-05-15T05:00:42Z",
      "exitCode": 0,
      "stdoutHash": "blake3:stdout",
      "stderrExcerptHash": "blake3:stderr-excerpt",
      "artifactManifestHash": "blake3:artifact-manifest",
      "retainedLogPathHash": "blake3:retained-log-path",
      "provenance": [
        {
          "source": "j1_jsonl",
          "eventKind": "artifact_manifest",
          "line": 2
        }
      ]
    }
  ]
}
