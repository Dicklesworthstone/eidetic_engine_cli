{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eidetic-engine/schemas/swarm/ee.coordination_fallback_evidence.v1.json",
  "title": "ee.coordination_fallback_evidence.v1",
  "description": "Redaction-safe evidence record for coordination substrate fallback incidents.",
  "type": "object",
  "required": [
    "schema",
    "evidenceId",
    "capturedAt",
    "status",
    "source",
    "reasonCode",
    "summary",
    "links",
    "fallbackAction",
    "redaction",
    "producer"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "const": "ee.coordination_fallback_evidence.v1"},
    "evidenceId": {"type": "string"},
    "capturedAt": {"type": ["string", "null"], "format": "date-time"},
    "status": {"type": "string", "enum": ["available", "unavailable", "stale", "blocked", "unknown"]},
    "source": {
      "type": "object",
      "required": ["kind", "sourceId"],
      "additionalProperties": false,
      "properties": {
        "kind": {"type": "string", "enum": ["agent_mail", "beads", "file_reservation", "rch", "bv", "git", "other"]},
        "sourceId": {"type": "string"}
      }
    },
    "reasonCode": {"type": "string"},
    "summary": {
      "type": "object",
      "required": ["text", "contentHash", "redacted"],
      "additionalProperties": false,
      "properties": {
        "text": {"type": "string"},
        "contentHash": {"type": "string"},
        "redacted": {"type": "boolean"}
      }
    },
    "links": {
      "type": "object",
      "required": ["beadIds", "verificationIds", "supportBundleIds"],
      "additionalProperties": false,
      "properties": {
        "beadIds": {"type": "array", "items": {"type": "string"}},
        "verificationIds": {"type": "array", "items": {"type": "string"}},
        "supportBundleIds": {"type": "array", "items": {"type": "string"}}
      }
    },
    "fallbackAction": {
      "type": "object",
      "required": ["kind", "summary", "command", "manualStep"],
      "additionalProperties": false,
      "properties": {
        "kind": {"type": "string", "enum": ["record_only", "beads_comment", "support_bundle", "retry_later", "manual_coordination"]},
        "summary": {"type": "string"},
        "command": {"type": ["string", "null"]},
        "manualStep": {"type": ["string", "null"]}
      }
    },
    "redaction": {
      "type": "object",
      "required": ["rawInboxIncluded", "rawLogIncluded", "secretScanApplied", "pathPolicy"],
      "additionalProperties": false,
      "properties": {
        "rawInboxIncluded": {"type": "boolean"},
        "rawLogIncluded": {"type": "boolean"},
        "secretScanApplied": {"type": "boolean"},
        "pathPolicy": {"type": "string", "enum": ["none", "redact_home", "hash_paths", "labels_only"]}
      }
    },
    "producer": {"$ref": "ee.producer.metadata.v1.json"}
  },
  "examples": [
