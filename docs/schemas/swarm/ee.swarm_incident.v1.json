{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eidetic-engine/schemas/swarm/ee.swarm_incident.v1.json",
  "title": "ee.swarm_incident.v1",
  "description": "Synthetic incident rehearsal scenario for deterministic swarm coordination, disk, RCH, and hot-path degradation drills.",
  "type": "object",
  "required": ["schema", "scenarioId", "fixedClock", "purpose", "substrates", "expectedDegraded", "expectedRecoveryActions", "redactionExpectations", "assertions", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "const": "ee.swarm_incident.v1"},
    "scenarioId": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "fixedClock": {"type": "string", "format": "date-time"},
    "purpose": {"type": "string"},
    "substrates": {
      "type": "object",
      "required": ["agentMail", "beads", "rch", "disk", "hotPath"],
      "additionalProperties": false,
      "properties": {
        "agentMail": {"$ref": "#/$defs/substrate"},
        "beads": {"$ref": "#/$defs/substrate"},
        "rch": {"$ref": "#/$defs/substrate"},
        "disk": {"$ref": "#/$defs/substrate"},
        "hotPath": {"$ref": "#/$defs/substrate"}
      }
    },
    "expectedDegraded": {
      "type": "array",
      "items": {"$ref": "#/$defs/degradation"}
    },
    "expectedRecoveryActions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/recoveryAction"}
    },
    "redactionExpectations": {
      "type": "object",
      "required": ["pathPolicy", "secretPolicy", "allowedHostLabels"],
      "additionalProperties": false,
      "properties": {
        "pathPolicy": {"type": "string", "enum": ["redact_home", "synthetic_only"]},
        "secretPolicy": {"type": "string", "enum": ["no_secrets", "redacted_markers_only"]},
        "allowedHostLabels": {"type": "array", "items": {"type": "string"}}
      }
    },
    "assertions": {
      "type": "object",
      "required": ["deterministic", "noLiveServices", "noLocalCargo", "noDeletion", "noMutation"],
      "additionalProperties": false,
      "properties": {
        "deterministic": {"type": "boolean"},
        "noLiveServices": {"type": "boolean"},
        "noLocalCargo": {"type": "boolean"},
        "noDeletion": {"type": "boolean"},
        "noMutation": {"type": "boolean"}
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string"},
          "kind": {"type": "string", "enum": ["fixture", "schema", "doc", "e2e_log", "support_summary"]}
        }
      }
    }
  },
  "$defs": {
    "substrate": {
      "type": "object",
      "required": ["status", "evidence", "degradedCodes", "metrics"],
      "additionalProperties": false,
      "properties": {
        "status": {"type": "string", "enum": ["ok", "unavailable", "stale", "blocked", "degraded", "not_applicable"]},
        "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "degradedCodes": {"type": "array", "items": {"type": "string"}},
        "metrics": {
          "type": "object",
          "additionalProperties": {"type": ["string", "integer", "number", "boolean", "null"]}
        }
      }
    },
    "degradation": {
      "type": "object",
      "required": ["code", "severity", "surface", "reason"],
      "additionalProperties": false,
      "properties": {
        "code": {"type": "string"},
        "severity": {"type": "string", "enum": ["info", "low", "warning", "medium", "high", "critical"]},
        "surface": {"type": "string"},
        "reason": {"type": "string"}
      }
    },
    "recoveryAction": {
      "type": "object",
      "required": ["priority", "kind", "summary", "command", "manualStep", "evidence", "destructive", "preconditions"],
      "additionalProperties": false,
      "properties": {
        "priority": {"type": "integer", "minimum": 1},
        "kind": {"type": "string", "enum": ["observe", "refresh", "retry", "repair", "escalate", "manual"]},
        "summary": {"type": "string"},
        "command": {"type": ["string", "null"]},
        "manualStep": {"type": ["string", "null"]},
        "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "destructive": {"type": "boolean"},
        "preconditions": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "examples": [
    {
      "schema": "ee.swarm_incident.v1",
      "scenarioId": "rch_topology_blocked",
      "fixedClock": "2026-05-15T00:00:00Z",
      "purpose": "RCH fleet is healthy, but remote-required Cargo verification is blocked before execution by path topology.",
      "substrates": {
        "agentMail": {"status": "ok", "evidence": ["inbox fetch succeeds"], "degradedCodes": [], "metrics": {"unread": 0, "ackRequired": 0}},
        "beads": {"status": "ok", "evidence": ["br doctor ok"], "degradedCodes": [], "metrics": {"jsonlRecords": 1848, "cycles": 0}},
        "rch": {"status": "blocked", "evidence": ["RCH-E327 alias root is not a symlink: /data/projects"], "degradedCodes": ["rch_worker_topology_blocked", "rch_remote_required_fallback_prevented"], "metrics": {"workersHealthy": 3, "localFallback": false}},
        "disk": {"status": "ok", "evidence": ["CARGO_TARGET_DIR uses external scratch"], "degradedCodes": [], "metrics": {"externalTarget": true}},
        "hotPath": {"status": "not_applicable", "evidence": ["no search/context burst in this scenario"], "degradedCodes": [], "metrics": {}}
      },
      "expectedDegraded": [
        {"code": "rch_worker_topology_blocked", "severity": "warning", "surface": "diag incident", "reason": "Remote-required Cargo cannot start until the path topology policy accepts the local /data/projects alias layout."},
        {"code": "rch_remote_required_fallback_prevented", "severity": "medium", "surface": "diag incident", "reason": "Local Cargo fallback is explicitly forbidden for this repository."}
      ],
      "expectedRecoveryActions": [
        {"priority": 1, "kind": "observe", "summary": "Capture RCH status and exact topology error before changing code.", "command": "rch status --workers --jobs --json", "manualStep": null, "evidence": ["RCH-E327"], "destructive": false, "preconditions": []},
        {"priority": 2, "kind": "repair", "summary": "Install or build a patched native macOS RCH client; do not run local Cargo as fallback.", "command": null, "manualStep": "Coordinate on bd-18i4h and verify the patched RCH client before retrying ee Cargo gates.", "evidence": ["bd-18i4h"], "destructive": false, "preconditions": ["RCH source patch is reviewed", "native client install is approved"]}
      ],
      "redactionExpectations": {"pathPolicy": "redact_home", "secretPolicy": "no_secrets", "allowedHostLabels": ["css", "csd", "trj"]},
      "assertions": {"deterministic": true, "noLiveServices": true, "noLocalCargo": true, "noDeletion": true, "noMutation": true},
      "artifacts": [
        {"path": "tests/fixtures/swarm_incidents/rch_topology_blocked.json", "kind": "fixture"},
        {"path": "docs/schemas/swarm/ee.swarm_incident.v1.json", "kind": "schema"}
      ]
    }
  ],
  "x-ee-status": {
    "shipped": false,
    "tracking_bead": "bd-1zb7k.14.1",
    "available_in_build": false,
    "feature_flag": null,
    "expected_version": "0.4.0"
  },
  "x-ee-doc": "docs/swarm/swarm_incident_drills.md"
}
